{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "luxury",
  "description": "奢侈高端 · 深炭黑 + 拉丝金、衬线 display、留白即高级、细金描边、极克制阴影。暗为主。给高端时装/珠宝/腕表/酒店/私人银行/会员制品牌与精品电商。",
  "note": "本风格暗为主：默认（:root / data-theme=dark / .dark）即暗色；亮（米金）模式用 data-theme=light 覆盖。",
  "color": {
    "dark": {
      "bg": "#0e0d0b",
      "bg-subtle": "#121009",
      "bg-elevated": "#16140f",
      "bg-sunken": "#0a0907",
      "fg": "#ece6d8",
      "fg-muted": "#9a9486",
      "fg-subtle": "#857d6c",
      "fg-on-accent": "#0e0d0b",
      "border": "#2a261d",
      "border-strong": "#3a3528",
      "primary": "#c9a86a",
      "primary-hover": "#b8975a",
      "primary-active": "#a8854a",
      "primary-fg": "#0e0d0b",
      "accent": "#c9a86a",
      "accent-fg": "#0e0d0b",
      "success": "#7fb389",
      "success-bg": "#172418",
      "success-fg": "#d6ecd8",
      "warning": "#d8b25a",
      "warning-bg": "#26200c",
      "warning-fg": "#f5eccf",
      "danger": "#e08274",
      "danger-bg": "#2a1310",
      "danger-fg": "#f6ddd6",
      "info": "#74a3c2",
      "info-bg": "#10212c",
      "info-fg": "#d6e7f1",
      "focus": "#c9a86a"
    },
    "light": {
      "bg": "#f6f3ee",
      "bg-subtle": "#efeae1",
      "bg-elevated": "#fffdf9",
      "bg-sunken": "#ebe5da",
      "fg": "#1a1714",
      "fg-muted": "#5f574a",
      "fg-subtle": "#6b6356",
      "fg-on-accent": "#f6f3ee",
      "border": "#e3dccf",
      "border-strong": "#d3c9b6",
      "primary": "#1a1714",
      "primary-hover": "#322c25",
      "primary-active": "#0e0c0a",
      "primary-fg": "#f6f3ee",
      "accent": "#7e5f28",
      "accent-fg": "#f6f3ee",
      "success": "#3f6b46",
      "success-bg": "#e6efe6",
      "success-fg": "#1f3a25",
      "warning": "#9a6b08",
      "warning-bg": "#f6edd6",
      "warning-fg": "#4f3a05",
      "danger": "#a23a2c",
      "danger-bg": "#f5e3df",
      "danger-fg": "#561a12",
      "info": "#3a5f7a",
      "info-bg": "#e3ecf2",
      "info-fg": "#1c3140",
      "focus": "#7e5f28"
    }
  },
  "radius": {
    "sm": "2px",
    "md": "6px",
    "lg": "10px",
    "full": "9999px"
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "32px",
    "8": "40px",
    "9": "48px",
    "10": "64px",
    "11": "80px",
    "12": "96px"
  },
  "font": {
    "serif": "\"Noto Serif\", \"Source Han Serif SC\", \"Noto Serif SC\", \"Songti SC\", Georgia, \"Times New Roman\", serif",
    "sans": "\"Inter\", -apple-system, \"Segoe UI\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
    "mono": "\"JetBrains Mono\", ui-monospace, \"SF Mono\", Menlo, monospace"
  },
  "text": {
    "xs": "12px",
    "sm": "13px",
    "base": "15px",
    "md": "18px",
    "lg": "22px",
    "xl": "30px",
    "2xl": "42px",
    "3xl": "60px"
  },
  "leading": {
    "tight": "1.15",
    "normal": "1.5",
    "relaxed": "1.75"
  },
  "weight": {
    "normal": "400",
    "medium": "500",
    "bold": "600"
  },
  "tracking": {
    "tight": "-0.02em",
    "normal": "0"
  },
  "shadow": {
    "dark": {
      "sm": "0 1px 2px rgba(0,0,0,.5)",
      "md": "0 2px 6px -3px rgba(0,0,0,.55), 0 10px 24px -14px rgba(0,0,0,.7)",
      "lg": "0 4px 10px -4px rgba(0,0,0,.6), 0 22px 44px -20px rgba(0,0,0,.8)"
    },
    "light": {
      "sm": "0 1px 2px rgba(26,23,20,.05)",
      "md": "0 1px 2px rgba(26,23,20,.04), 0 6px 16px -8px rgba(26,23,20,.1)",
      "lg": "0 2px 4px rgba(26,23,20,.05), 0 16px 36px -14px rgba(26,23,20,.14)"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.22,.61,.36,1)",
    "dur-fast": "160ms",
    "dur-base": "260ms",
    "dur-slow": "380ms"
  },
  "image": {
    "treatment": "full-bleed 优雅；细金描边（1px var(--ds-border) 或金线）；圆角小（2/6/10）；阴影克制；适度留白，别塞满。",
    "container-max": "1120px"
  }
}
