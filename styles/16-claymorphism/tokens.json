      "border": "#3a3a5a",
      "border-strong": "#4a4a70",
      "primary": "#9a8cff",
      "primary-hover": "#aa9eff",
      "primary-active": "#8a7cf5",
      "primary-fg": "#1a1330",
      "accent": "#38d6b0",
      "accent-fg": "#053229",
      "success": "#44d3a3",
      "success-bg": "#12352a",
      "success-fg": "#bdf5e3",
      "warning": "#ffc874",
      "warning-bg": "#3a2a0c",
