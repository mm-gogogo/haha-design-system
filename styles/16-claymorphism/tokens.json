{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "claymorphism",
  "description": "黏土 3D · 胖嘟嘟柔软黏土质感，马卡龙色 + 大圆角 + 外柔影 + inset 内高光，俏皮充气感，给儿童/教育/健康/休闲社交/创意工具类产品。",
  "color": {
    "light": {
      "bg": "#eef0fb",
