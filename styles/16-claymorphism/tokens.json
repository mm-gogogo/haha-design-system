      "info": "#9a8cff",
      "info-bg": "#25214a",
      "info-fg": "#ddd7ff",
      "focus": "#9a8cff"
    }
  },
  "radius": {
    "sm": "16px",
    "md": "24px",
    "lg": "32px",
    "full": "9999px"
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "32px",
    "8": "40px",
    "9": "48px",
    "10": "64px",
    "11": "80px",
    "12": "96px"
  },
  "font": {
    "sans": "\"Quicksand\", \"Varela Round\", -apple-system, \"Segoe UI\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
    "serif": "\"Quicksand\", Georgia, \"Songti SC\", serif",
    "mono": "\"SF Mono\", ui-monospace, Menlo, \"Cascadia Code\", monospace"
  },
  "text": {
    "xs": "12px",
    "sm": "13px",
    "base": "14px",
    "md": "16px",
    "lg": "20px",
    "xl": "24px",
    "2xl": "32px",
    "3xl": "48px"
  },
  "leading": {
    "tight": "1.2",
    "normal": "1.55",
    "relaxed": "1.75"
  },
  "weight": {
    "normal": "500",
    "medium": "600",
    "bold": "700"
  },
  "tracking": {
    "tight": "-0.02em",
    "normal": "0"
  },
  "shadow": {
    "light": {
      "sm": "0 6px 14px -6px rgba(86,80,158,.28), inset 0 2px 2px rgba(255,255,255,.9), inset 0 -3px 5px rgba(86,80,158,.12)",
      "md": "0 14px 28px -10px rgba(86,80,158,.32), inset 0 3px 3px rgba(255,255,255,.95), inset 0 -5px 8px rgba(86,80,158,.14)",
      "lg": "0 26px 48px -14px rgba(86,80,158,.36), inset 0 4px 4px rgba(255,255,255,.95), inset 0 -7px 12px rgba(86,80,158,.16)",
      "clay-raised": "0 16px 30px -12px rgba(86,80,158,.34), inset 0 3px 4px rgba(255,255,255,.95), inset 0 -6px 10px rgba(86,80,158,.16)",
      "clay-pressed": "0 4px 10px -6px rgba(86,80,158,.22), inset 0 5px 9px rgba(86,80,158,.22), inset 0 -2px 3px rgba(255,255,255,.7)",
      "clay-accent": "0 16px 30px -12px rgba(124,108,255,.5), inset 0 3px 4px rgba(255,255,255,.55), inset 0 -7px 11px rgba(60,46,150,.4)"
    },
    "dark": {
      "sm": "0 6px 14px -6px rgba(0,0,0,.55), inset 0 2px 2px rgba(255,255,255,.10), inset 0 -3px 5px rgba(0,0,0,.4)",
      "md": "0 14px 28px -10px rgba(0,0,0,.6), inset 0 3px 3px rgba(255,255,255,.12), inset 0 -5px 8px rgba(0,0,0,.45)",
      "lg": "0 26px 48px -14px rgba(0,0,0,.66), inset 0 4px 4px rgba(255,255,255,.12), inset 0 -7px 12px rgba(0,0,0,.5)",
      "clay-raised": "0 16px 30px -12px rgba(0,0,0,.62), inset 0 3px 4px rgba(255,255,255,.12), inset 0 -6px 10px rgba(0,0,0,.48)",
      "clay-pressed": "0 4px 10px -6px rgba(0,0,0,.5), inset 0 5px 9px rgba(0,0,0,.55), inset 0 -2px 3px rgba(255,255,255,.08)",
      "clay-accent": "0 16px 30px -12px rgba(0,0,0,.6), inset 0 3px 4px rgba(255,255,255,.25), inset 0 -7px 11px rgba(0,0,0,.45)"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.34,1.56,.64,1)",
    "dur-fast": "180ms",
    "dur-base": "240ms",
    "dur-slow": "320ms"
  },
  "z": {
    "base": 0,
    "dropdown": 1000,
    "sticky": 1100,
    "modal-backdrop": 1200,
    "modal": 1300,
    "toast": 1400,
    "tooltip": 1500
  }
}
