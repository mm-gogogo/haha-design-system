{
  "$meta": {
    "name": "Cyberpunk / 赛博朋克风",
    "description": "暗色优先的霓虹夜城风。暗紫底 + 霓虹品红/青/电黄强调 + 发光、扫描线、轻故障感 + 等宽字。注意 :root=暗色，[data-theme=\"light\"]/.light 为亮色覆盖（与多数风格相反）。",
    "version": "1.0.0",
    "contract": "ds-token-contract@1",
    "themeStrategy": "dark-first",
    "base": "dark",
    "override": "light"
  },
  "color": {
    "dark": {
      "bg": "#0a0612",
      "bg-subtle": "#100a1c",
      "bg-elevated": "#14091f",
      "bg-sunken": "#070410",
      "fg": "#e8e0ff",
      "fg-muted": "#9a86c0",
      "fg-subtle": "#8a78ac",
      "fg-on-accent": "#0a0612",
      "border": "#2a1a3a",
      "border-strong": "#422a5c",
      "primary": "#ff2bd6",
      "primary-hover": "#ff52e0",
      "primary-active": "#e016ba",
      "primary-fg": "#0a0612",
      "accent": "#00f0ff",
      "accent-fg": "#04121a",
      "success": "#1fffb0", "success-bg": "#052418", "success-fg": "#a6ffe2",
      "warning": "#ffe600", "warning-bg": "#2a2400", "warning-fg": "#fff4a3",
      "danger": "#ff3b6b", "danger-bg": "#2c0713", "danger-fg": "#ffc2d2",
      "info": "#00f0ff", "info-bg": "#042430", "info-fg": "#aef4ff",
      "focus": "#00f0ff"
    },
    "light": {
      "bg": "#ffffff",
      "bg-subtle": "#f7f4fb",
      "bg-elevated": "#ffffff",
      "bg-sunken": "#f0ebf7",
      "fg": "#1a1026",
      "fg-muted": "#574a6b",
      "fg-subtle": "#6e6285",
      "fg-on-accent": "#ffffff",
      "border": "#e6dcf0",
      "border-strong": "#cdbce0",
      "primary": "#c40d9e",
      "primary-hover": "#d61bb0",
      "primary-active": "#a4067f",
      "primary-fg": "#ffffff",
      "accent": "#00708a",
      "accent-fg": "#ffffff",
      "success": "#0a7f57", "success-bg": "#e4f9f0", "success-fg": "#044029",
      "warning": "#8a6d00", "warning-bg": "#fdf6d6", "warning-fg": "#443600",
      "danger": "#d11240", "danger-bg": "#ffe8ee", "danger-fg": "#6b0a22",
      "info": "#0073a8", "info-bg": "#e2f4fb", "info-fg": "#003a55",
      "focus": "#00708a"
    }
  },
  "focusRing": {
    "dark": "0 0 0 2px #0a0612, 0 0 0 4px #00f0ff, 0 0 16px -2px rgba(0,240,255,.6)",
    "light": "0 0 0 2px #ffffff, 0 0 0 4px #00708a, 0 0 10px -3px rgba(0,112,138,.4)"
  },
  "radius": {
    "sm": "2px",
    "md": "6px",
    "lg": "10px",
    "full": "9999px"
  },
  "space": {
    "1": "4px", "2": "8px", "3": "12px", "4": "16px",
    "5": "20px", "6": "24px", "7": "32px", "8": "40px",
    "9": "48px", "10": "64px", "11": "80px", "12": "96px"
  },
  "font": {
    "sans": "\"Inter\", -apple-system, \"Segoe UI\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
    "serif": "\"Inter\", Georgia, \"Songti SC\", serif",
    "mono": "\"JetBrains Mono\", ui-monospace, \"SF Mono\", Menlo, Consolas, monospace"
  },
  "fontSize": {
    "xs": "12px", "sm": "13px", "base": "14px", "md": "16px",
    "lg": "20px", "xl": "24px", "2xl": "32px", "3xl": "48px"
  },
  "leading": {
    "tight": "1.2",
    "normal": "1.5",
    "relaxed": "1.7"
  },
  "weight": {
    "normal": "400",
    "medium": "500",
    "bold": "600"
  },
  "tracking": {
    "tight": "-0.04em",
    "normal": "0"
  },
  "shadow": {
    "dark": {
      "sm": "0 0 0 1px #2a1a3a, 0 2px 8px -3px rgba(0,0,0,.7)",
      "md": "0 0 0 1px #2a1a3a, 0 10px 28px -10px rgba(0,0,0,.8), 0 0 26px -10px rgba(255,43,214,.28)",
      "lg": "0 0 0 1px #2a1a3a, 0 18px 50px -14px rgba(0,0,0,.85), 0 0 44px -12px rgba(0,240,255,.32)"
    },
    "light": {
      "sm": "0 0 0 1px #e6dcf0, 0 2px 4px -2px rgba(26,16,38,.08)",
      "md": "0 0 0 1px #e6dcf0, 0 8px 24px -8px rgba(26,16,38,.12), 0 0 20px -12px rgba(196,13,158,.16)",
      "lg": "0 0 0 1px #e6dcf0, 0 16px 48px -12px rgba(26,16,38,.16), 0 0 28px -14px rgba(0,112,138,.18)"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.2,.8,.2,1)",
    "dur-fast": "150ms",
    "dur-base": "200ms",
    "dur-slow": "260ms"
  }
}
