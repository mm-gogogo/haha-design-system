{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "constructivism",
  "description": "构成主义设计系统 Token —— 旧纸米色、红黑强对比、斜向构成、粗黑规则线、红黑双色照片拼贴与重型 grotesque 排版。",
  "color": {
    "light": {
      "bg": "#ece4d3",
      "bg-subtle": "#e0d6c0",
      "bg-elevated": "#f7f1e3",
      "bg-sunken": "#d4c8ac",
      "fg": "#1a1714",
      "fg-muted": "#4a4339",
      "fg-subtle": "#6e6454",
      "fg-on-accent": "#f7f1e3",
      "border": "#c9bb9c",
      "border-strong": "#1a1714",
      "primary": "#c1271f",
      "primary-hover": "#a51f18",
      "primary-active": "#8a1812",
      "primary-fg": "#f7f1e3",
      "accent": "#1a1714",
      "accent-fg": "#f7f1e3",
      "success": "#3a6b2e",
      "success-bg": "#e6efe0",
      "success-fg": "#13310e",
      "warning": "#9a6a14",
      "warning-bg": "#f4e8cf",
      "warning-fg": "#43300a",
      "danger": "#c1271f",
      "danger-bg": "#f6e0dc",
      "danger-fg": "#5a120c",
      "info": "#1f4a6b",
      "info-bg": "#e0e9f0",
      "info-fg": "#0c2436",
      "focus": "#c1271f"
    },
    "dark": {
      "bg": "#15120e",
      "bg-subtle": "#1c1813",
      "bg-elevated": "#221d16",
      "bg-sunken": "#0d0b08",
      "fg": "#f0e8d6",
      "fg-muted": "#b4a890",
      "fg-subtle": "#847a64",
      "fg-on-accent": "#fff8ec",
      "border": "#342d22",
      "border-strong": "#f0e8d6",
      "primary": "#e0392c",
      "primary-hover": "#ec4d40",
      "primary-active": "#cf2e22",
      "primary-fg": "#fff8ec",
      "accent": "#f0e8d6",
      "accent-fg": "#15120e",
      "success": "#6fbf6f",
      "success-bg": "#102a10",
      "success-fg": "#cdeec0",
      "warning": "#e0b35a",
      "warning-bg": "#241a06",
      "warning-fg": "#f6e6be",
      "danger": "#e0392c",
      "danger-bg": "#2a0c08",
      "danger-fg": "#f8d6cf",
      "info": "#5a9fd0",
      "info-bg": "#0a2030",
      "info-fg": "#d6e8f5",
      "focus": "#e0392c"
    }
  },
  "focusRing": "0 0 0 2px var(--ds-bg),0 0 0 4px var(--ds-focus)",
  "radius": {
    "sm": "0px",
    "md": "0px",
    "lg": "2px",
    "full": "9999px"
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "32px",
    "8": "40px",
    "9": "48px",
    "10": "64px",
    "11": "80px",
    "12": "96px"
  },
  "font": {
    "sans": "\"Inter\", -apple-system, \"PingFang SC\", sans-serif",
    "serif": "\"Noto Serif\", serif",
    "mono": "\"JetBrains Mono\", monospace"
  },
  "text": {
    "xs": "12px",
    "sm": "13px",
    "base": "14px",
    "md": "16px",
    "lg": "20px",
    "xl": "24px",
    "2xl": "32px",
    "3xl": "48px"
  },
  "leading": {
    "tight": "1.2",
    "normal": "1.5",
    "relaxed": "1.7"
  },
  "weight": {
    "normal": "400",
    "medium": "500",
    "bold": "600"
  },
  "tracking": {
    "tight": "-0.02em",
    "normal": "0"
  },
  "shadow": {
    "light": {
      "sm": "2px 2px 0 var(--ds-border-strong)",
      "md": "4px 4px 0 var(--ds-border-strong)",
      "lg": "8px 8px 0 var(--ds-border-strong)"
    },
    "dark": {
      "sm": "2px 2px 0 var(--ds-border-strong)",
      "md": "4px 4px 0 var(--ds-border-strong)",
      "lg": "8px 8px 0 rgba(0,0,0,.6)"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.22,.61,.36,1)",
    "dur-fast": "150ms",
    "dur-base": "200ms",
    "dur-slow": "250ms"
  }
}
