{
  "$meta": {
    "name": "B-side / 后台控制台",
    "description": "高密度、信息优先、中性克制的后台控制台设计系统。表格/表单友好，效率至上。",
    "version": "1.0.0",
    "base": "geist",
    "themes": ["light", "dark"]
  },
  "color": {
    "light": {
      "bg": "#ffffff",
      "bg-subtle": "#f5f6f8",
      "bg-elevated": "#ffffff",
      "bg-sunken": "#eef0f3",
      "fg": "#1d2129",
      "fg-muted": "#4e5969",
      "fg-subtle": "#86909c",
      "fg-on-accent": "#ffffff",
      "border": "#e5e6eb",
      "border-strong": "#c9cdd4",
      "primary": "#165dff",
      "primary-hover": "#0e42d2",
      "primary-active": "#0a30a0",
      "primary-fg": "#ffffff",
      "accent": "#165dff",
      "accent-fg": "#ffffff",
      "success": "#00b42a",
      "success-bg": "#e8ffea",
      "success-fg": "#006622",
      "warning": "#ff7d00",
      "warning-bg": "#fff7e8",
      "warning-fg": "#8c4b00",
      "danger": "#f53f3f",
      "danger-bg": "#ffece8",
      "danger-fg": "#a8071a",
      "info": "#165dff",
      "info-bg": "#e8f3ff",
      "info-fg": "#0a30a0",
      "focus": "#165dff"
    },
    "dark": {
      "bg": "#17171a",
      "bg-subtle": "#1d1d20",
      "bg-elevated": "#232328",
      "bg-sunken": "#131316",
      "fg": "#e8e8ea",
      "fg-muted": "#9da0a8",
      "fg-subtle": "#6b6e76",
      "fg-on-accent": "#ffffff",
      "border": "#2e2e33",
      "border-strong": "#44454c",
      "primary": "#2f6fea",
      "primary-hover": "#5c95ff",
      "primary-active": "#1f63e6",
      "primary-fg": "#ffffff",
      "accent": "#2f6fea",
      "accent-fg": "#ffffff",
      "success": "#27c346",
      "success-bg": "#0f2914",
      "success-fg": "#aef2bd",
      "warning": "#ff9a2e",
      "warning-bg": "#2e1c07",
      "warning-fg": "#ffdcae",
      "danger": "#ff6b6b",
      "danger-bg": "#2e1213",
      "danger-fg": "#ffc9c9",
      "info": "#3c7eff",
      "info-bg": "#0e1c3a",
      "info-fg": "#bcd6ff",
      "focus": "#3c7eff"
    }
  },
  "radius": {
    "sm": "4px",
    "md": "6px",
    "lg": "8px",
    "full": "9999px"
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "32px",
    "8": "40px",
    "9": "48px",
    "10": "64px",
    "11": "80px",
    "12": "96px"
  },
  "control": {
    "sm": "24px",
    "md": "32px",
    "lg": "36px"
  },
  "font": {
    "sans": "\"Inter\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", \"PingFang SC\", \"Microsoft YaHei\", \"Hiragino Sans GB\", Arial, sans-serif",
    "serif": "Georgia, \"Songti SC\", \"SimSun\", serif",
    "mono": "\"SF Mono\", \"JetBrains Mono\", ui-monospace, Menlo, Consolas, \"Courier New\", monospace",
    "size": {
      "xs": "12px",
      "sm": "13px",
      "base": "14px",
      "md": "16px",
      "lg": "18px",
      "xl": "20px",
      "2xl": "24px",
      "3xl": "30px"
    },
    "leading": {
      "tight": "1.3",
      "normal": "1.5",
      "relaxed": "1.7"
    },
    "weight": {
      "normal": "400",
      "medium": "500",
      "bold": "600"
    },
    "tracking": {
      "tight": "-0.01em",
      "normal": "0"
    },
    "numeric": "tabular-nums"
  },
  "shadow": {
    "light": {
      "sm": "0 1px 2px rgba(29,33,41,.04)",
      "md": "0 2px 8px rgba(29,33,41,.08), 0 1px 2px rgba(29,33,41,.04)",
      "lg": "0 4px 16px rgba(29,33,41,.12), 0 2px 4px rgba(29,33,41,.06)"
    },
    "dark": {
      "sm": "0 1px 2px rgba(0,0,0,.4)",
      "md": "0 2px 8px rgba(0,0,0,.5), 0 1px 2px rgba(0,0,0,.4)",
      "lg": "0 4px 16px rgba(0,0,0,.6), 0 2px 4px rgba(0,0,0,.4)"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.25,.1,.25,1)",
    "duration": {
      "fast": "120ms",
      "base": "160ms",
      "slow": "200ms"
    }
  }
}
