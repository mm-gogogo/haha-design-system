{
  "$meta": {
    "name": "天文星图 / Celestial Star-Atlas",
    "description": "暗色优先的古典天文星图风格。深午夜靛蓝夜空、古金铜版刻线、分级星点、赤经/赤纬网格、黄道弧与星盘装饰；亮色为冷调浅蓝灰天文纸图。强调清晰发丝线与档案级排版，不使用发光或科技终端语言。",
    "version": "1.0.0",
    "contract": "ds-token-contract@1",
    "themeStrategy": "dark-first",
    "base": "dark",
    "override": "light"
  },
  "color": {
    "dark": {
      "bg": "#0b1026",
      "bg-subtle": "#0e1430",
      "bg-elevated": "#161c3c",
      "bg-sunken": "#070a1c",
      "fg": "#e9e7f6",
      "fg-muted": "#aaacce",
      "fg-subtle": "#7e81a6",
      "fg-on-accent": "#07131c",
      "border": "#272e54",
      "border-strong": "#3c4577",
      "primary": "#d4a94a",
      "primary-hover": "#e2b95e",
      "primary-active": "#c19a3c",
      "primary-fg": "#1a1530",
      "accent": "#74bcd8",
      "accent-fg": "#07131c",
      "success": "#7bb893", "success-bg": "#16261d", "success-fg": "#aee0bf",
      "warning": "#e0b25e", "warning-bg": "#2a2010", "warning-fg": "#f3d79a",
      "danger": "#e08a80", "danger-bg": "#2c1614", "danger-fg": "#f4b8b0",
      "info": "#74bcd8", "info-bg": "#0e2530", "info-fg": "#b0e0f0",
      "focus": "#d4a94a"
    },
    "light": {
      "bg": "#eaecf4",
      "bg-subtle": "#e2e5f0",
      "bg-elevated": "#f7f8fc",
      "bg-sunken": "#dadeec",
      "fg": "#181c30",
      "fg-muted": "#474c69",
      "fg-subtle": "#6a6f8e",
      "fg-on-accent": "#ffffff",
      "border": "#ccd2e4",
      "border-strong": "#aab2cf",
      "primary": "#876219",
      "primary-hover": "#6f5113",
      "primary-active": "#5c4310",
      "primary-fg": "#ffffff",
      "accent": "#2a6b86",
      "accent-fg": "#ffffff",
      "success": "#2f7d54", "success-bg": "#e2f0e7", "success-fg": "#14502f",
      "warning": "#8a6410", "warning-bg": "#f5ecd6", "warning-fg": "#5a4108",
      "danger": "#b23b30", "danger-bg": "#f6e2df", "danger-fg": "#7d2019",
      "info": "#2a6b86", "info-bg": "#ddeef4", "info-fg": "#134456",
      "focus": "#876219"
    }
  },
  "focusRing": {
    "dark": "0 0 0 2px #0b1026, 0 0 0 4px #d4a94a",
    "light": "0 0 0 2px #eaecf4, 0 0 0 4px #876219"
  },
  "radius": {
    "sm": "3px",
    "md": "6px",
    "lg": "10px",
    "full": "999px"
  },
  "space": {
    "1": "4px", "2": "8px", "3": "12px", "4": "16px",
    "5": "20px", "6": "24px", "7": "32px", "8": "40px",
    "9": "48px", "10": "64px", "11": "80px", "12": "96px"
  },
  "font": {
    "sans": "\"Inter\", -apple-system, \"Segoe UI\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
    "serif": "\"Noto Serif\", Georgia, \"Songti SC\", serif",
    "mono": "\"JetBrains Mono\", ui-monospace, \"SF Mono\", Menlo, Consolas, monospace"
  },
  "fontSize": {
    "xs": "12px", "sm": "13px", "base": "14px", "md": "16px",
    "lg": "20px", "xl": "24px", "2xl": "32px", "3xl": "48px"
  },
  "leading": {
    "tight": "1.2",
    "normal": "1.5",
    "relaxed": "1.7"
  },
  "weight": {
    "normal": "400",
    "medium": "500",
    "bold": "600"
  },
  "tracking": {
    "tight": "0",
    "normal": "0"
  },
  "shadow": {
    "dark": {
      "sm": "0 0 0 1px #272e54, 0 1px 0 rgba(212,169,74,.14)",
      "md": "0 0 0 1px #272e54, 0 1px 0 rgba(212,169,74,.12), inset 0 1px 0 rgba(233,231,246,.04)",
      "lg": "0 0 0 1px #3c4577, 0 2px 0 rgba(0,0,0,.28), inset 0 1px 0 rgba(212,169,74,.10)"
    },
    "light": {
      "sm": "0 0 0 1px #ccd2e4, 0 1px 0 rgba(24,28,48,.06)",
      "md": "0 0 0 1px #ccd2e4, 0 1px 0 rgba(24,28,48,.08), inset 0 1px 0 rgba(255,255,255,.6)",
      "lg": "0 0 0 1px #aab2cf, 0 2px 0 rgba(24,28,48,.10), inset 0 1px 0 rgba(255,255,255,.7)"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.22,.61,.36,1)",
    "dur-fast": "140ms",
    "dur-base": "220ms",
    "dur-slow": "360ms"
  }
