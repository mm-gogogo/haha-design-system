{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "editorial",
  "description": "📖 极简 editorial 风 · 暖纸基底、衬线正文、大留白大行高、单一克制赭橙强调。给阅读站 / 博客 / 文档 / 内容社区 / 长文。",
  "color": {
    "light": {
      "bg": "#faf8f3",
      "bg-subtle": "#f3efe6",
      "bg-elevated": "#fffdf8",
      "bg-sunken": "#ece7db",
      "fg": "#2b2722",
      "fg-muted": "#5c554a",
      "fg-subtle": "#6f6757",
      "fg-on-accent": "#fdf6ef",
      "border": "#e5dfd2",
      "border-strong": "#d4ccbb",
      "primary": "#b4541e",
      "primary-hover": "#9c4517",
      "primary-active": "#823609",
      "primary-fg": "#fdf6ef",
      "accent": "#3f6f5f",
      "accent-fg": "#fdf6ef",
      "success": "#4a7c59",
      "success-bg": "#e9f1e8",
      "success-fg": "#244430",
      "warning": "#b8860b",
      "warning-bg": "#f7efd8",
      "warning-fg": "#5e4404",
      "danger": "#b03a2e",
      "danger-bg": "#f7e5e0",
      "danger-fg": "#5e1a13",
      "info": "#3f6f8f",
      "info-bg": "#e4eef3",
      "info-fg": "#1d3a4c",
      "focus": "#b4541e"
    },
    "dark": {
      "bg": "#1a1714",
      "bg-subtle": "#221e1a",
      "bg-elevated": "#2a2520",
      "bg-sunken": "#15110e",
      "fg": "#ece5d8",
      "fg-muted": "#b3a994",
      "fg-subtle": "#8f846f",
      "fg-on-accent": "#1a1714",
      "border": "#3a342c",
      "border-strong": "#524a3e",
      "primary": "#d97746",
      "primary-hover": "#e2885a",
      "primary-active": "#c9663a",
      "primary-fg": "#1a1714",
      "accent": "#7bae9c",
      "accent-fg": "#112019",
      "success": "#7bb389",
      "success-bg": "#1a2c1f",
      "success-fg": "#d7ecdb",
      "warning": "#d8a93a",
      "warning-bg": "#2e2408",
      "warning-fg": "#f6e8c2",
      "danger": "#e07a6c",
      "danger-bg": "#341511",
      "danger-fg": "#f7ddd6",
      "info": "#6fa3c2",
      "info-bg": "#122631",
      "info-fg": "#d6e8f1",
      "focus": "#d97746"
    }
  },
  "radius": {
    "sm": "6px",
    "md": "10px",
    "lg": "14px",
    "full": "9999px"
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "32px",
    "8": "40px",
    "9": "48px",
    "10": "64px",
    "11": "80px",
    "12": "96px"
  },
  "font": {
    "serif": "\"Source Han Serif SC\", \"Noto Serif SC\", \"Songti SC\", Georgia, \"Times New Roman\", serif",
    "sans": "\"Inter\", -apple-system, \"Segoe UI\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
    "mono": "\"JetBrains Mono\", ui-monospace, \"SF Mono\", Menlo, monospace"
  },
  "text": {
    "xs": "13px",
    "sm": "14px",
    "base": "17px",
    "md": "19px",
    "lg": "22px",
    "xl": "28px",
    "2xl": "38px",
    "3xl": "52px"
  },
  "leading": {
    "tight": "1.25",
    "normal": "1.55",
    "relaxed": "1.85"
  },
  "weight": {
    "normal": "400",
    "medium": "500",
    "bold": "600"
  },
  "tracking": {
    "tight": "-0.015em",
    "normal": "0"
  },
  "shadow": {
    "light": {
      "sm": "0 1px 2px rgba(43,39,34,.04)",
      "md": "0 1px 2px rgba(43,39,34,.03), 0 4px 12px -6px rgba(43,39,34,.08)",
      "lg": "0 2px 4px rgba(43,39,34,.04), 0 12px 28px -10px rgba(43,39,34,.12)"
    },
    "dark": {
      "sm": "0 1px 2px rgba(0,0,0,.4)",
      "md": "0 2px 6px -2px rgba(0,0,0,.5), 0 8px 20px -10px rgba(0,0,0,.6)",
      "lg": "0 4px 10px -2px rgba(0,0,0,.55), 0 16px 32px -12px rgba(0,0,0,.7)"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.22,.61,.36,1)",
    "dur-fast": "160ms",
    "dur-base": "240ms",
    "dur-slow": "300ms"
  },
  "reading": {
    "container-max": "680px",
    "note": "阅读容器 max-width 约 40rem/680px；标题 text-wrap balance、字距略紧；正文 text-wrap pretty。"
  }
}
