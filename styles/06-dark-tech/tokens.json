{
  "$meta": {
    "name": "Dark Tech / 暗黑科技风",
    "description": "暗色优先的开发者/AI 控制台风。纯黑近黑底 + 霓虹青强调 + 终端代码感 + 辉光阴影。注意 :root=暗色，[data-theme=\"light\"]/.light 为亮色覆盖（与其它风格相反）。",
    "version": "1.0.0",
    "contract": "ds-token-contract@1",
    "themeStrategy": "dark-first",
    "base": "dark",
    "override": "light"
  },
  "color": {
    "dark": {
      "bg": "#0a0a0f",
      "bg-subtle": "#111119",
      "bg-elevated": "#14141c",
      "bg-sunken": "#08080c",
      "fg": "#e6e6f0",
      "fg-muted": "#9a9ab0",
      "fg-subtle": "#62627a",
      "fg-on-accent": "#04120f",
      "border": "#26263a",
      "border-strong": "#383850",
      "primary": "#00e0c6",
      "primary-hover": "#2af0d8",
      "primary-active": "#00c2ab",
      "primary-fg": "#04120f",
      "accent": "#8b5cf6",
      "accent-fg": "#0a0612",
      "success": "#00e676", "success-bg": "#06231a", "success-fg": "#9affc9",
      "warning": "#ffb020", "warning-bg": "#261800", "warning-fg": "#ffe2a8",
      "danger": "#ff4d6d", "danger-bg": "#2a0a12", "danger-fg": "#ffc4cf",
      "info": "#00b3ff", "info-bg": "#04203a", "info-fg": "#b3e6ff",
      "focus": "#00e0c6"
    },
    "light": {
      "bg": "#ffffff",
      "bg-subtle": "#f6f7f9",
      "bg-elevated": "#ffffff",
      "bg-sunken": "#eef0f3",
      "fg": "#0e1117",
      "fg-muted": "#51596b",
      "fg-subtle": "#6b7385",
      "fg-on-accent": "#ffffff",
      "border": "#e1e4ea",
      "border-strong": "#c7ccd6",
      "primary": "#00786a",
      "primary-hover": "#008f7e",
      "primary-active": "#005f54",
      "primary-fg": "#ffffff",
      "accent": "#7c3aed",
      "accent-fg": "#ffffff",
      "success": "#07823f", "success-bg": "#e6f8ee", "success-fg": "#044523",
      "warning": "#9a6400", "warning-bg": "#fff4e0", "warning-fg": "#4d3200",
      "danger": "#d11a3f", "danger-bg": "#ffe9ee", "danger-fg": "#6b0a20",
      "info": "#0073c4", "info-bg": "#e5f3ff", "info-fg": "#003a66",
      "focus": "#00786a"
    }
  },
  "focusRing": {
    "dark": "0 0 0 2px #0a0a0f, 0 0 0 4px #00e0c6, 0 0 14px -2px rgba(0,224,198,.55)",
    "light": "0 0 0 2px #ffffff, 0 0 0 4px #00786a, 0 0 10px -3px rgba(0,120,106,.35)"
  },
  "radius": {
    "sm": "6px",
    "md": "10px",
    "lg": "14px",
    "full": "9999px"
  },
  "space": {
    "1": "4px", "2": "8px", "3": "12px", "4": "16px",
    "5": "20px", "6": "24px", "7": "32px", "8": "40px",
    "9": "48px", "10": "64px", "11": "80px", "12": "96px"
  },
  "font": {
    "sans": "\"Geist\", \"Inter\", -apple-system, \"Segoe UI\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
    "serif": "\"Geist\", Georgia, \"Songti SC\", serif",
    "mono": "\"JetBrains Mono\", \"Geist Mono\", ui-monospace, \"SF Mono\", Menlo, Consolas, monospace"
  },
  "fontSize": {
    "xs": "12px", "sm": "13px", "base": "14px", "md": "16px",
    "lg": "20px", "xl": "24px", "2xl": "32px", "3xl": "48px"
  },
  "leading": {
    "tight": "1.2",
    "normal": "1.5",
    "relaxed": "1.7"
  },
  "weight": {
    "normal": "400",
    "medium": "500",
    "bold": "600"
  },
  "tracking": {
    "tight": "-0.02em",
    "normal": "0"
  },
  "shadow": {
    "dark": {
      "sm": "0 0 0 1px #26263a, 0 2px 6px -2px rgba(0,0,0,.6)",
      "md": "0 0 0 1px #26263a, 0 8px 24px -8px rgba(0,0,0,.7), 0 0 24px -10px rgba(0,224,198,.25)",
      "lg": "0 0 0 1px #26263a, 0 16px 48px -12px rgba(0,0,0,.8), 0 0 40px -12px rgba(0,224,198,.35)"
    },
    "light": {
      "sm": "0 0 0 1px #e1e4ea, 0 2px 4px -2px rgba(16,17,23,.08)",
      "md": "0 0 0 1px #e1e4ea, 0 8px 24px -8px rgba(16,17,23,.12), 0 0 20px -12px rgba(0,120,106,.18)",
      "lg": "0 0 0 1px #e1e4ea, 0 16px 48px -12px rgba(16,17,23,.16), 0 0 28px -14px rgba(0,120,106,.22)"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.2,.8,.2,1)",
    "dur-fast": "150ms",
    "dur-base": "200ms",
    "dur-slow": "250ms"
  }
}
