{
  "$meta": {
    "name": "90s Web / Web 1.0",
    "description": "A polished early-web homepage kit with tiled wallpaper, beveled buttons, marquee strips, visitor counters, web-ring navigation, and Times-like headings.",
    "version": "1.0.0",
    "contract": "ds-token-contract@1"
  },
  "color": {
    "light": {
      "bg": "#dfe3ec",
      "bg-subtle": "#cdd3e0",
      "bg-elevated": "#ffffff",
      "bg-sunken": "#b8c0d0",
      "fg": "#0a0a1a",
      "fg-muted": "#2c2c50",
      "fg-subtle": "#4a4a6a",
      "fg-on-accent": "#ffffff",
      "border": "#8a90a8",
      "border-strong": "#0a0a1a",
      "primary": "#1818c0",
      "primary-hover": "#1010a0",
      "primary-active": "#0c0c80",
      "primary-fg": "#ffffff",
      "accent": "#c01878",
      "accent-fg": "#ffffff",
      "success": "#1a7a1a", "success-bg": "#e0f0e0", "success-fg": "#0a3a0a",
      "warning": "#a85a00", "warning-bg": "#f6ead0", "warning-fg": "#3a2000",
      "danger": "#c01010", "danger-bg": "#f6e0e0", "danger-fg": "#4a0808",
      "info": "#1818c0", "info-bg": "#e0e0f6", "info-fg": "#0c0c50",
      "focus": "#1818c0"
    },
    "dark": {
      "bg": "#07071a",
      "bg-subtle": "#0e0e26",
      "bg-elevated": "#14143a",
      "bg-sunken": "#050510",
      "fg": "#e4e4ff",
      "fg-muted": "#a6a6d8",
      "fg-subtle": "#7676a8",
      "fg-on-accent": "#04102a",
      "border": "#2c2c5e",
      "border-strong": "#e4e4ff",
      "primary": "#5ab0ff",
      "primary-hover": "#7ac2ff",
      "primary-active": "#4a9cf0",
      "primary-fg": "#04102a",
      "accent": "#ff5ad8",
      "accent-fg": "#2a0420",
      "success": "#5fd35f", "success-bg": "#08240a", "success-fg": "#cdeec0",
      "warning": "#f0b84a", "warning-bg": "#241a06", "warning-fg": "#f6e6be",
      "danger": "#ff6a6a", "danger-bg": "#2a0c0c", "danger-fg": "#ffd6d6",
      "info": "#5ab0ff", "info-bg": "#08182a", "info-fg": "#d6e8ff",
      "focus": "#5ab0ff"
    }
  },
  "focusRing": {
    "light": "0 0 0 2px #dfe3ec, 0 0 0 4px #1818c0",
    "dark": "0 0 0 2px #07071a, 0 0 0 4px #5ab0ff"
  },
  "radius": {
    "sm": "0px",
    "md": "2px",
    "lg": "4px",
    "full": "9999px"
  },
  "space": {
    "1": "4px", "2": "8px", "3": "12px", "4": "16px",
    "5": "20px", "6": "24px", "7": "32px", "8": "40px",
    "9": "48px", "10": "64px", "11": "80px", "12": "96px"
  },
  "font": {
    "serif": "\"Noto Serif\", \"Times New Roman\", Georgia, serif",
    "sans": "\"Inter\", -apple-system, \"PingFang SC\", sans-serif",
    "mono": "\"VT323\", \"JetBrains Mono\", monospace"
  },
  "fontSize": {
    "xs": "12px", "sm": "13px", "base": "15px", "md": "17px",
    "lg": "22px", "xl": "28px", "2xl": "38px", "3xl": "56px"
  },
  "leading": {
    "tight": "1.15",
    "normal": "1.5",
    "relaxed": "1.7"
  },
  "weight": {
    "normal": "400",
    "medium": "400",
    "bold": "700"
  },
  "tracking": {
    "tight": "0",
    "normal": "0.02em"
  },
  "shadow": {
    "light": {
      "sm": "1px 1px 0 var(--ds-border-strong)",
      "md": "2px 2px 0 var(--ds-border-strong)",
      "lg": "4px 4px 0 var(--ds-border-strong)"
    },
    "dark": {
      "sm": "1px 1px 0 rgba(0,0,0,.6)",
      "md": "2px 2px 0 rgba(0,0,0,.6)",
      "lg": "4px 4px 0 rgba(0,0,0,.7)"
    }
  },
  "motion": {
    "ease": "steps(4, end)",
    "dur-fast": "80ms",
    "dur-base": "140ms",
    "dur-slow": "240ms"
  }
}
