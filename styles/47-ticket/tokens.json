  "shadow": {
    "light": {
      "sm": "0 1px 0 rgba(31, 29, 26, .05), 0 0 0 1px var(--ds-border)",
      "md": "0 8px 18px -14px rgba(31, 29, 26, .28), 0 0 0 1px var(--ds-border)",
      "lg": "0 18px 40px -26px rgba(31, 29, 26, .38), 0 0 0 1px var(--ds-border-strong)"
    },
    "dark": {
      "sm": "0 1px 0 rgba(0, 0, 0, .28), 0 0 0 1px var(--ds-border)",
