  "motion": {
    "ease": "cubic-bezier(.2, .8, .2, 1)",
    "dur-fast": "120ms",
    "dur-base": "200ms",
    "dur-slow": "320ms"
  },
  "ticketing": {
    "authority": "环线票务 · Loop Transit & Post",
    "container-max": "1120px",
    "note": "Ticket layouts use two-part pass cards with a dashed perforation between the main body and stub, mono serial/date/gate fields, barcode strips, guilloche security hairlines, and a rotated validation seal. Mobile collapses stubs under the ticket body to avoid overflow at 390px."
  }
