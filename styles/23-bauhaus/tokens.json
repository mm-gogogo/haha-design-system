{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "bauhaus",
  "description": "包豪斯风设计系统 Token —— 暖画布、黑色硬描边、蓝/红/黄基础几何、非对称网格与功能主义排版。",
  "color": {
    "light": {
      "bg": "#f4f1e8",
      "bg-subtle": "#ebe6d8",
      "bg-elevated": "#fffdf8",
      "bg-sunken": "#e3ddca",
      "fg": "#1a1a1a",
      "fg-muted": "#4a4a4a",
      "fg-subtle": "#6e6e6e",
      "fg-on-accent": "#ffffff",
      "border": "#ddd6c4",
      "border-strong": "#1a1a1a",
      "primary": "#1b3fae",
      "primary-hover": "#163590",
      "primary-active": "#112a73",
      "primary-fg": "#ffffff",
      "accent": "#c1272d",
      "accent-fg": "#ffffff",
      "success": "#1f7a3d",
      "success-bg": "#e3f1e7",
      "success-fg": "#0a3a1c",
      "warning": "#9a6a00",
      "warning-bg": "#fbeecb",
      "warning-fg": "#473006",
      "danger": "#c1272d",
      "danger-bg": "#f8e2e1",
      "danger-fg": "#5a1010",
      "info": "#1b3fae",
      "info-bg": "#e3e8f7",
      "info-fg": "#0e2057",
      "focus": "#1b3fae"
    },
    "dark": {
      "bg": "#141414",
      "bg-subtle": "#1c1c1c",
      "bg-elevated": "#202020",
      "bg-sunken": "#0c0c0c",
      "fg": "#f0ede4",
      "fg-muted": "#a8a8a8",
      "fg-subtle": "#888888",
      "fg-on-accent": "#ffffff",
      "border": "#2e2e2e",
      "border-strong": "#f0ede4",
      "primary": "#3f63d6",
      "primary-hover": "#4e72e2",
      "primary-active": "#3354c0",
      "primary-fg": "#ffffff",
      "accent": "#e8635f",
      "accent-fg": "#160606",
      "success": "#4cc26a",
      "success-bg": "#0c2614",
      "success-fg": "#c9f5d4",
      "warning": "#f5c518",
      "warning-bg": "#241c00",
      "warning-fg": "#fff0bf",
      "danger": "#ef6b66",
      "danger-bg": "#2a0e0d",
      "danger-fg": "#ffd4d1",
      "info": "#5a82ef",
      "info-bg": "#0e1838",
      "info-fg": "#d6e0ff",
      "focus": "#3f63d6"
    }
  },
  "focusRing": "0 0 0 2px var(--ds-bg),0 0 0 4px var(--ds-focus)",
  "radius": {
    "sm": "0px",
    "md": "0px",
    "lg": "0px",
    "full": "9999px"
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "32px",
    "8": "40px",
    "9": "48px",
    "10": "64px",
    "11": "80px",
    "12": "96px"
  },
  "font": {
    "sans": "\"Inter\", \"Helvetica Neue\", Arial, \"PingFang SC\", sans-serif",
    "serif": "\"Source Serif 4\", Georgia, \"Songti SC\", \"SimSun\", serif",
    "mono": "\"JetBrains Mono\", monospace"
  },
  "text": {
    "xs": "12px",
    "sm": "13px",
    "base": "14px",
    "md": "16px",
    "lg": "20px",
    "xl": "24px",
    "2xl": "32px",
    "3xl": "48px"
  },
  "leading": {
    "tight": "1.2",
    "normal": "1.5",
    "relaxed": "1.7"
  },
  "weight": {
    "normal": "400",
    "medium": "500",
    "bold": "600"
  },
  "tracking": {
    "tight": "-0.02em",
    "normal": "0"
  },
  "shadow": {
    "light": {
      "sm": "0 0 0 1px var(--ds-border)",
      "md": "0 0 0 1px var(--ds-border)",
      "lg": "0 0 0 2px var(--ds-border-strong)"
    },
    "dark": {
      "sm": "0 0 0 1px var(--ds-border)",
      "md": "0 0 0 1px var(--ds-border)",
      "lg": "0 0 0 2px var(--ds-border-strong)"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.22,.61,.36,1)",
    "dur-fast": "150ms",
    "dur-base": "200ms",
    "dur-slow": "250ms"
  }
}
