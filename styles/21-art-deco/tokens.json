{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "art-deco",
  "description": "装饰艺术 / Art Deco · 象牙奶油为底、深祖母绿为骨、金线为饰、墨为字；几何对称的太阳放射 / 人字 / 阶梯角，细双金线分隔；衬线大标题 + 宽字距大写小标。给 1920s 风格酒店 / 爵士俱乐部 / 剧院 / 香水屋等奢华几何品牌。",
  "color": {
    "light": {
      "bg": "#f6f1e7",
      "bg-subtle": "#efe7d6",
      "bg-elevated": "#fffdf8",
      "bg-sunken": "#e7dcc6",
      "fg": "#1a2420",
      "fg-muted": "#41514a",
      "fg-subtle": "#6a766e",
      "fg-on-accent": "#f6f1e7",
      "border": "#d8cdb4",
      "border-strong": "#2a3a33",
      "primary": "#0f5a44",
      "primary-hover": "#0c4a38",
      "primary-active": "#093829",
      "primary-fg": "#f6f1e7",
      "accent": "#8a6816",
      "accent-fg": "#f6f1e7",
      "success": "#0f5a44",
      "success-bg": "#e3f0e8",
      "success-fg": "#06291f",
      "warning": "#8a6816",
      "warning-bg": "#f6ecd2",
      "warning-fg": "#3e2f08",
      "danger": "#9e2b2b",
      "danger-bg": "#f6e0df",
      "danger-fg": "#4a1010",
      "info": "#1d4e6b",
      "info-bg": "#e0edf3",
      "info-fg": "#0c2533",
      "focus": "#0f5a44"
    },
    "dark": {
      "bg": "#0d1714",
      "bg-subtle": "#122019",
      "bg-elevated": "#16271f",
      "bg-sunken": "#081210",
      "fg": "#ede6d2",
      "fg-muted": "#a9b4a8",
      "fg-subtle": "#7d8a80",
      "fg-on-accent": "#0d1714",
      "border": "#2a3a31",
      "border-strong": "#c9a23f",
      "primary": "#d8b25a",
      "primary-hover": "#e3c172",
      "primary-active": "#c49e44",
      "primary-fg": "#0d1714",
      "accent": "#5fb89a",
      "accent-fg": "#06140f",
      "success": "#5fb89a",
      "success-bg": "#06291f",
      "success-fg": "#cdeede",
      "warning": "#e0b85a",
      "warning-bg": "#241a06",
      "warning-fg": "#f6e6be",
      "danger": "#e07a72",
      "danger-bg": "#2a0f0d",
      "danger-fg": "#f8d6d2",
      "info": "#6fb0d0",
      "info-bg": "#0a2230",
      "info-fg": "#cfe7f2",
      "focus": "#d8b25a"
    }
  },
  "radius": {
    "sm": "0px",
    "md": "2px",
    "lg": "3px",
    "full": "9999px"
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "32px",
    "8": "40px",
    "9": "48px",
    "10": "64px",
    "11": "80px",
    "12": "96px"
  },
  "font": {
    "serif": "\"Noto Serif\", Georgia, \"Songti SC\", serif",
    "sans": "\"Inter\", -apple-system, \"Segoe UI\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
    "mono": "\"JetBrains Mono\", ui-monospace, \"SF Mono\", Menlo, monospace"
  },
  "text": {
    "xs": "12px",
    "sm": "14px",
    "base": "16px",
    "md": "18px",
    "lg": "22px",
    "xl": "28px",
    "2xl": "38px",
    "3xl": "52px"
  },
  "leading": {
    "tight": "1.22",
    "normal": "1.55",
    "relaxed": "1.8"
  },
  "weight": {
    "normal": "400",
    "medium": "500",
    "bold": "700"
  },
  "tracking": {
    "tight": "-0.01em",
    "normal": "0"
  },
  "shadow": {
    "light": {
      "sm": "0 1px 2px rgba(26,36,32,.06)",
      "md": "0 6px 18px -10px rgba(26,36,32,.2)",
      "lg": "0 14px 36px -14px rgba(26,36,32,.24)"
    },
    "dark": {
      "sm": "0 1px 2px rgba(0,0,0,.5)",
      "md": "0 6px 18px -8px rgba(0,0,0,.6)",
      "lg": "0 16px 40px -14px rgba(0,0,0,.7)"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.22,.61,.36,1)",
    "dur-fast": "140ms",
    "dur-base": "220ms",
    "dur-slow": "320ms"
  },
  "z": {
    "dropdown": 30,
    "sticky": 20,
    "modal-backdrop": 50,
    "modal": 51,
    "toast": 60,
    "tooltip": 70
  },
  "note": "金为本风格的饰线与次强调色（--ds-accent）：用于细双金线分隔、太阳放射/人字纹的描边、阶梯角与链接。深祖母绿（--ds-primary）作主操作与品牌骨。暗色 primary 为金，故意配深字（--ds-primary-fg:#0d1714）以达 WCAG AA。其余变量严格遵守 --ds-* 契约。"
}
