{
  "$meta": {
    "name": "Blueprint / 蓝图技术风",
    "description": "暗色优先的工程蓝图/CAD 制图风。蓝图纸底、细白/青蓝技术线、双层 drafting grid、尺寸线、标题栏和等宽标注。平面哑光、1px 描边，无发光；注意 :root=暗色，[data-theme=\"light\"]/.light 为白底 CAD。",
    "version": "1.0.0",
    "contract": "ds-token-contract@1",
    "themeStrategy": "dark-first",
    "base": "dark",
    "override": "light"
  },
  "color": {
    "dark": {
      "bg": "#0d2747",
      "bg-subtle": "#123257",
      "bg-elevated": "#163a63",
      "bg-sunken": "#0a1f3a",
      "fg": "#e8f0fb",
      "fg-muted": "#a8c0e0",
      "fg-subtle": "#7c9cc4",
      "fg-on-accent": "#07203a",
      "border": "#2a4a72",
      "border-strong": "#5a82b8",
      "primary": "#7cc4ff",
      "primary-hover": "#9ad2ff",
      "primary-active": "#5aa6f0",
      "primary-fg": "#07203a",
      "accent": "#ffb84d",
      "accent-fg": "#2a1800",
      "success": "#5fd39a", "success-bg": "#06281c", "success-fg": "#c9f5dd",
      "warning": "#ffb84d", "warning-bg": "#241a06", "warning-fg": "#fff0cf",
      "danger": "#ff7a72", "danger-bg": "#2a0f0d", "danger-fg": "#ffd6d2",
      "info": "#7cc4ff", "info-bg": "#0a2342", "info-fg": "#d6e8fb",
      "focus": "#7cc4ff"
    },
    "light": {
      "bg": "#f4f7fb",
      "bg-subtle": "#e9eff6",
      "bg-elevated": "#ffffff",
      "bg-sunken": "#dfe8f4",
      "fg": "#122742",
      "fg-muted": "#44597a",
      "fg-subtle": "#6a7fa0",
      "fg-on-accent": "#ffffff",
      "border": "#cdd9ec",
      "border-strong": "#2f5a92",
      "primary": "#155fb0",
      "primary-hover": "#124f93",
      "primary-active": "#0f4178",
      "primary-fg": "#ffffff",
      "accent": "#9a6210",
      "accent-fg": "#ffffff",
      "success": "#1f7a4d", "success-bg": "#e2f1ea", "success-fg": "#0a3a26",
      "warning": "#9a6210", "warning-bg": "#f6ecd2", "warning-fg": "#42300a",
      "danger": "#b53a32", "danger-bg": "#f7e3e1", "danger-fg": "#5a160f",
      "info": "#155fb0", "info-bg": "#e3edf7", "info-fg": "#0c2a4f",
      "focus": "#155fb0"
    }
  },
  "focusRing": {
    "dark": "0 0 0 2px #0d2747, 0 0 0 4px #7cc4ff",
    "light": "0 0 0 2px #f4f7fb, 0 0 0 4px #155fb0"
  },
  "radius": {
    "sm": "0px",
    "md": "2px",
    "lg": "4px",
    "full": "9999px"
  },
  "space": {
    "1": "4px", "2": "8px", "3": "12px", "4": "16px",
    "5": "20px", "6": "24px", "7": "32px", "8": "40px",
    "9": "48px", "10": "64px", "11": "80px", "12": "96px"
  },
  "font": {
    "sans": "\"Inter\",-apple-system,\"PingFang SC\",sans-serif",
    "serif": "Georgia,\"Songti SC\",serif",
    "mono": "\"JetBrains Mono\",ui-monospace,monospace"
  },
  "fontSize": {
    "xs": "12px", "sm": "13px", "base": "14px", "md": "16px",
    "lg": "20px", "xl": "24px", "2xl": "32px", "3xl": "48px"
  },
  "leading": {
    "tight": "1.2",
    "normal": "1.5",
    "relaxed": "1.7"
  },
  "weight": {
    "normal": "400",
    "medium": "500",
    "bold": "600"
  },
  "tracking": {
    "tight": "-0.02em",
    "normal": "0"
  },
  "shadow": {
    "dark": {
      "sm": "0 0 0 1px #2a4a72",
      "md": "0 0 0 1px #2a4a72",
      "lg": "0 0 0 1px #5a82b8"
    },
    "light": {
      "sm": "0 0 0 1px #cdd9ec",
      "md": "0 0 0 1px #cdd9ec",
      "lg": "0 0 0 1px #2f5a92"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.2,.8,.2,1)",
    "dur-fast": "150ms",
    "dur-base": "200ms",
    "dur-slow": "250ms"
  }
}
