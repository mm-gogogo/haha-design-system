    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "32px",
    "8": "40px",
    "9": "48px",
    "10": "64px",
    "11": "80px",
    "12": "96px"
  },
  "font": {
    "sans": "\"Quicksand\",\"Inter\",-apple-system,\"PingFang SC\",sans-serif",
    "serif": "\"Quicksand\",\"Inter\",Georgia,\"Songti SC\",serif",
    "mono": "\"JetBrains Mono\",monospace"
  },
  "text": {
    "xs": "12px",
    "sm": "13px",
    "base": "14px",
    "md": "16px",
    "lg": "20px",
    "xl": "24px",
    "2xl": "32px",
    "3xl": "48px"
  },
  "leading": {
    "tight": "1.25",
    "normal": "1.55",
    "relaxed": "1.75"
  },
  "weight": {
    "normal": "500",
    "medium": "600",
    "bold": "700"
  },
  "tracking": {
    "tight": "0",
    "normal": "0.01em"
  },
  "shadow": {
    "light": {
      "sm": "0 2px 0 var(--ds-border-strong)",
      "md": "4px 4px 0 var(--ds-border-strong)",
      "lg": "8px 8px 0 var(--ds-border-strong)"
    },
    "dark": {
      "sm": "0 2px 0 rgba(0,0,0,.5)",
      "md": "4px 4px 0 rgba(0,0,0,.55)",
      "lg": "8px 8px 0 rgba(0,0,0,.6)"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.34,1.56,.64,1)",
    "dur-fast": "200ms",
    "dur-base": "260ms",
    "dur-slow": "320ms"
