{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "gov-cn",
  "description": "中国政府风（政务）设计系统 Token —— 庄重、权威、规整、可信。双主色：党政红 #c4161c + 政务蓝 #1c4d8c，金色描边点缀；小而方正的圆角，克制阴影。Geist 语义骨架。",
  "color": {
    "light": {
      "bg": "#ffffff",
      "bg-subtle": "#f5f3f0",
      "bg-elevated": "#ffffff",
      "bg-sunken": "#efece6",
      "fg": "#1a1a1a",
      "fg-muted": "#4a4a4a",
      "fg-subtle": "#757575",
      "fg-on-accent": "#ffffff",
      "border": "#e0ddd6",
      "border-strong": "#c8c4ba",
      "primary": "#c4161c",
      "primary-hover": "#a91219",
      "primary-active": "#8c0f15",
      "primary-fg": "#ffffff",
      "accent": "#1c4d8c",
      "accent-fg": "#ffffff",
      "gold": "#c9a227",
      "success": "#2e7d32",
      "success-bg": "#eaf3ea",
      "success-fg": "#14401a",
      "warning": "#c77700",
      "warning-bg": "#fbf1e0",
      "warning-fg": "#5e3800",
      "danger": "#c4161c",
      "danger-bg": "#fbe9e9",
      "danger-fg": "#5e0a0d",
      "info": "#1c4d8c",
      "info-bg": "#e9f0f8",
      "info-fg": "#0d2848",
      "focus": "#1c4d8c"
    },
    "dark": {
      "bg": "#14181f",
      "bg-subtle": "#1a1f28",
      "bg-elevated": "#1f2530",
      "bg-sunken": "#0f131a",
      "fg": "#ededed",
      "fg-muted": "#b3b8c0",
      "fg-subtle": "#828892",
      "fg-on-accent": "#ffffff",
      "border": "#2a313d",
      "border-strong": "#3c4554",
      "primary": "#e23b41",
      "primary-hover": "#ec5258",
      "primary-active": "#c4161c",
      "primary-fg": "#ffffff",
      "accent": "#4a86d6",
      "accent-fg": "#0b1018",
      "gold": "#d9b441",
      "success": "#57b85e",
      "success-bg": "#0f2613",
      "success-fg": "#cdeecf",
      "warning": "#e0992e",
      "warning-bg": "#2a1d05",
      "warning-fg": "#f7e2b8",
      "danger": "#e85a5f",
      "danger-bg": "#2c1213",
      "danger-fg": "#ffd6d7",
      "info": "#4a86d6",
      "info-bg": "#0d1f38",
      "info-fg": "#d4e4f7",
      "focus": "#4a86d6"
    }
  },
  "focusRing": "0 0 0 2px var(--ds-bg), 0 0 0 4px var(--ds-focus)",
  "radius": {
    "sm": "2px",
    "md": "4px",
    "lg": "6px",
    "full": "9999px"
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "32px",
    "8": "40px",
    "9": "48px",
    "10": "64px",
    "11": "80px",
    "12": "96px"
  },
  "font": {
    "sans": "\"Source Han Sans SC\", \"Noto Sans SC\", \"PingFang SC\", \"Microsoft YaHei\", \"Hiragino Sans GB\", \"Heiti SC\", sans-serif",
    "serif": "\"Source Han Serif SC\", \"Noto Serif SC\", \"Songti SC\", \"STSong\", \"SimSun\", serif",
    "mono": "\"Source Han Mono SC\", ui-monospace, \"SF Mono\", Menlo, Consolas, monospace"
  },
  "text": {
    "xs": "12px",
    "sm": "13px",
    "base": "14px",
    "md": "16px",
    "lg": "20px",
    "xl": "24px",
    "2xl": "32px",
    "3xl": "48px"
  },
  "leading": {
    "tight": "1.25",
    "normal": "1.6",
    "relaxed": "1.9"
  },
  "weight": {
    "normal": "400",
    "medium": "500",
    "bold": "700"
  },
  "tracking": {
    "tight": "0",
    "normal": "0"
  },
  "shadow": {
    "light": {
      "sm": "0 1px 0 rgba(26,26,26,.04)",
      "md": "0 1px 2px rgba(26,26,26,.06), 0 4px 10px -6px rgba(26,26,26,.12)",
      "lg": "0 2px 4px rgba(26,26,26,.06), 0 12px 28px -10px rgba(26,26,26,.18)"
    },
    "dark": {
      "sm": "0 1px 0 rgba(0,0,0,.4)",
      "md": "0 1px 2px rgba(0,0,0,.5), 0 4px 12px -6px rgba(0,0,0,.6)",
      "lg": "0 2px 4px rgba(0,0,0,.55), 0 16px 32px -10px rgba(0,0,0,.7)"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.4,0,.2,1)",
    "dur-fast": "150ms",
    "dur-base": "200ms",
    "dur-slow": "250ms"
  }
}
