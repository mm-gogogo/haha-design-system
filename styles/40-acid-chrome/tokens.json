{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "acid-chrome",
  "description": "Acid Chrome · 酸性镀铬（Y2K Chrome / Acid Graphics）· 暗色优先的酸性荧光绿、液态铬金属、虹彩 blob 与厚圆角高光组件。为原创俱乐部夜场、音乐厂牌、球鞋 / 街头服饰 drop、能量饮品活动而设。正文与组件保持 WCAG AA；虹彩仅用于装饰填充，chrome wordmark 仅作 hero 展示中心。",
  "color": {
    "light": {
      "bg": "#f4f6f0",
      "bg-subtle": "#e9ede2",
      "bg-elevated": "#ffffff",
      "bg-sunken": "#dde2d4",
      "fg": "#14180e",
      "fg-muted": "#44503a",
      "fg-subtle": "#5f6e52",
      "fg-on-accent": "#ffffff",
      "border": "#d2dac6",
      "border-strong": "#14180e",
      "primary": "#4a8a00",
      "primary-hover": "#3f7800",
      "primary-active": "#356600",
      "primary-fg": "#ffffff",
      "accent": "#7b2ff0",
      "accent-fg": "#ffffff",
      "success": "#1f8a4c",
      "success-bg": "#e2f3e8",
      "success-fg": "#0c3a20",
      "warning": "#8a6a00",
      "warning-bg": "#f6eece",
      "warning-fg": "#3e3000",
      "danger": "#c0322a",
      "danger-bg": "#f8e2df",
      "danger-fg": "#551410",
      "info": "#1f6fd0",
      "info-bg": "#e2ebfb",
      "info-fg": "#0e2c5e",
      "focus": "#4a8a00"
    },
    "dark": {
      "bg": "#0a0c0a",
      "bg-subtle": "#11140f",
      "bg-elevated": "#161a13",
      "bg-sunken": "#050604",
      "fg": "#eaffea",
      "fg-muted": "#a8c4a0",
      "fg-subtle": "#7e9874",
      "fg-on-accent": "#0a1400",
      "border": "#283022",
      "border-strong": "#b6ff3a",
      "primary": "#b6ff3a",
      "primary-hover": "#c8ff5e",
      "primary-active": "#a2ec28",
      "primary-fg": "#0a1400",
      "accent": "#a85cff",
      "accent-fg": "#ffffff",
      "success": "#6ee07a",
      "success-bg": "#06220e",
      "success-fg": "#c9f5cd",
      "warning": "#ffd23a",
      "warning-bg": "#241c00",
      "warning-fg": "#fff0b8",
      "danger": "#ff5f6e",
      "danger-bg": "#260a0e",
      "danger-fg": "#ffd2d6",
      "info": "#4bc8ff",
      "info-bg": "#06202a",
      "info-fg": "#cdeeff",
      "focus": "#b6ff3a"
    }
  },
  "radius": {
    "sm": "8px",
    "md": "16px",
    "lg": "28px",
    "full": "9999px"
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "32px",
    "8": "40px",
    "9": "48px",
    "10": "64px",
    "11": "80px",
    "12": "96px"
  },
  "font": {
    "sans": "\"Quicksand\",\"Inter\",-apple-system,\"PingFang SC\",sans-serif",
    "serif": "\"Quicksand\",\"Inter\",Georgia,\"Songti SC\",serif",
    "mono": "\"JetBrains Mono\",monospace"
  },
  "text": {
    "xs": "12px",
    "sm": "13px",
    "base": "14px",
    "md": "16px",
    "lg": "20px",
    "xl": "24px",
    "2xl": "32px",
    "3xl": "48px"
  },
  "leading": {
    "tight": "1.2",
    "normal": "1.55",
    "relaxed": "1.75"
  },
  "weight": {
    "normal": "400",
    "medium": "500",
    "bold": "600"
  },
  "tracking": {
    "tight": "-0.02em",
    "normal": "0"
  },
  "shadow": {
    "light": {
      "sm": "0 2px 8px -2px rgba(20,24,14,.16)",
      "md": "0 12px 28px -10px rgba(20,24,14,.24)",
      "lg": "0 24px 56px -16px rgba(20,24,14,.3)",
      "gloss-top": "inset 0 1px 0 rgba(255,255,255,.72)"
    },
    "dark": {
      "sm": "0 2px 8px -2px rgba(0,0,0,.5)",
      "md": "0 12px 28px -10px rgba(0,0,0,.6)",
      "lg": "0 24px 56px -16px rgba(0,0,0,.7), 0 0 32px -8px rgba(182,255,58,.3)",
      "gloss-top": "inset 0 1px 0 rgba(255,255,255,.2)"
    }
  },
  "gloss": {
    "blur": "8px",
    "blur-sm": "4px"
  },
  "z": {
    "dropdown": 1000,
    "sticky": 1100,
    "modal-backdrop": 1200,
    "modal": 1300,
    "toast": 1400,
    "tooltip": 1500
  },
  "motion": {
    "ease": "cubic-bezier(.2,.8,.2,1)",
    "dur-fast": "140ms",
    "dur-base": "220ms",
    "dur-slow": "360ms"
  }
