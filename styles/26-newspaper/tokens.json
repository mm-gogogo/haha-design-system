{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "newspaper",
  "description": "Newspaper · 报刊风 (Broadsheet): masthead-led classic newspaper system with serif headlines and body, dense columns, hairline rules, flat keylines, newsprint paper, ink black, and one editorial red.",
  "color": {
    "light": {
      "bg": "#f2efe8",
      "bg-subtle": "#e9e5da",
      "bg-elevated": "#fbf9f3",
      "bg-sunken": "#e2ddd0",
      "fg": "#1a1a18",
      "fg-muted": "#4a4a45",
      "fg-subtle": "#6e6e66",
      "fg-on-accent": "#f6f3ea",
      "border": "#d6d0c2",
      "border-strong": "#1a1a18",
      "primary": "#1f1f1c",
      "primary-hover": "#000000",
      "primary-active": "#000000",
      "primary-fg": "#f6f3ea",
      "accent": "#a8201a",
      "accent-fg": "#ffffff",
      "success": "#1f6e3a",
      "success-bg": "#e4f0e6",
      "success-fg": "#0a3219",
      "warning": "#8a5e10",
      "warning-bg": "#f5ecce",
      "warning-fg": "#42300a",
      "danger": "#a8201a",
      "danger-bg": "#f6e0de",
      "danger-fg": "#561010",
      "info": "#1d4e7a",
      "info-bg": "#e2ecf4",
      "info-fg": "#0c2740",
      "focus": "#a8201a"
    },
    "dark": {
      "bg": "#161512",
      "bg-subtle": "#1d1b16",
      "bg-elevated": "#211f19",
      "bg-sunken": "#100f0b",
      "fg": "#ece8dc",
      "fg-muted": "#aaa595",
      "fg-subtle": "#7e7a6c",
      "fg-on-accent": "#161512",
      "border": "#34322a",
      "border-strong": "#ece8dc",
      "primary": "#e8e4d8",
      "primary-hover": "#fffdf4",
      "primary-active": "#d6d2c6",
      "primary-fg": "#161512",
      "accent": "#e0564e",
      "accent-fg": "#1a0a08",
      "success": "#5fb87a",
      "success-bg": "#0e2a1a",
      "success-fg": "#cdeed7",
      "warning": "#d6b25a",
      "warning-bg": "#241c08",
      "warning-fg": "#f6e6be",
      "danger": "#e0564e",
      "danger-bg": "#2a0e0c",
      "danger-fg": "#f8d4d0",
      "info": "#6fa6d0",
      "info-bg": "#0c2030",
      "info-fg": "#cfe6f4",
      "focus": "#e0564e"
    }
  },
  "radius": {
    "sm": "0px",
    "md": "0px",
    "lg": "0px",
    "full": "9999px"
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "32px",
    "8": "40px",
    "9": "48px",
    "10": "64px",
    "11": "80px",
    "12": "96px"
  },
  "font": {
    "serif": "\"Noto Serif\", Georgia, \"Songti SC\", serif",
    "sans": "\"Inter\",-apple-system,\"PingFang SC\",sans-serif",
    "mono": "\"JetBrains Mono\",monospace"
  },
  "text": {
    "xs": "13px",
    "sm": "14px",
    "base": "17px",
    "md": "19px",
    "lg": "22px",
    "xl": "28px",
    "2xl": "38px",
    "3xl": "52px"
  },
  "leading": {
    "tight": "1.25",
    "normal": "1.55",
    "relaxed": "1.85"
  },
  "weight": {
    "normal": "400",
    "medium": "500",
    "bold": "600"
  },
  "tracking": {
    "tight": "-0.015em",
    "normal": "0"
  },
  "shadow": {
    "light": {
      "sm": "0 0 0 1px var(--ds-border)",
      "md": "0 0 0 1px var(--ds-border)",
      "lg": "0 0 0 1px var(--ds-border-strong)"
    },
    "dark": {
      "sm": "0 0 0 1px var(--ds-border)",
      "md": "0 0 0 1px var(--ds-border)",
      "lg": "0 0 0 1px var(--ds-border-strong)"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.22,.61,.36,1)",
    "dur-fast": "160ms",
    "dur-base": "240ms",
    "dur-slow": "300ms"
  },
  "reading": {
    "container-max": "1120px",
    "note": "Broadsheet layouts use a 1120px page with 2-3 CSS columns, hairline column rules, justified serif body, drop caps, decks, bylines, and mobile collapse to one column under 640px."
  }
}
