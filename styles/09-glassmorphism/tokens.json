{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "glassmorphism",
  "description": "玻璃拟态 · 半透明玻璃面 + backdrop-filter:blur + 1px 高光描边 + 鲜艳渐变垫底。通透、轻盈、有空气感，给作品集 / 落地页 / 仪表盘 / 媒体应用。承载文字的玻璃面提高不透明度以守住 WCAG AA。",
  "color": {
    "light": {
      "bg": "#eef1f8",
      "bg-subtle": "#e6eaf5",
      "bg-elevated": "rgba(255,255,255,.72)",
      "bg-sunken": "rgba(255,255,255,.42)",
      "fg": "#14182a",
      "fg-muted": "#44496a",
      "fg-subtle": "#565b7d",
      "fg-on-accent": "#ffffff",
      "border": "rgba(255,255,255,.60)",
      "border-strong": "rgba(255,255,255,.85)",
      "primary": "#5b5ef0",
      "primary-hover": "#4f51e6",
      "primary-active": "#4346d4",
      "primary-fg": "#ffffff",
      "accent": "#db2777",
      "accent-fg": "#ffffff",
      "success": "#0e9f6e",
      "success-bg": "#d7f2e6",
      "success-fg": "#0f6e4e",
      "warning": "#b97e0c",
      "warning-bg": "#fbecd2",
      "warning-fg": "#7a4a06",
      "danger": "#e02424",
      "danger-bg": "#fbe0e3",
      "danger-fg": "#9b1c2e",
      "info": "#5b5ef0",
      "info-bg": "#e2e8fd",
      "info-fg": "#1d3a8a",
      "focus": "#5b5ef0"
    },
    "dark": {
      "bg": "#0f1226",
      "bg-subtle": "#0c0f20",
      "bg-elevated": "rgba(255,255,255,.14)",
      "bg-sunken": "rgba(255,255,255,.07)",
      "fg": "#eef0ff",
      "fg-muted": "#aeb2da",
      "fg-subtle": "#9499c9",
      "fg-on-accent": "#ffffff",
      "border": "rgba(255,255,255,.18)",
      "border-strong": "rgba(255,255,255,.32)",
      "primary": "#818cf8",
      "primary-hover": "#939dfa",
      "primary-active": "#a3acff",
      "primary-fg": "#0c1033",
      "accent": "#f472b6",
      "accent-fg": "#2a0a18",
      "success": "#34d399",
      "success-bg": "#103226",
      "success-fg": "#7be0b0",
      "warning": "#fbbf24",
      "warning-bg": "#332306",
      "warning-fg": "#f0c069",
      "danger": "#f87171",
      "danger-bg": "#361a22",
      "danger-fg": "#f7a3ac",
      "info": "#818cf8",
      "info-bg": "#18203f",
      "info-fg": "#aab4ff",
      "focus": "#818cf8"
    }
  },
  "radius": {
    "sm": "16px",
    "md": "20px",
    "lg": "28px",
    "full": "9999px"
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "32px",
    "8": "40px",
    "9": "48px",
    "10": "64px",
    "11": "80px",
    "12": "96px"
  },
  "font": {
    "sans": "\"Inter\", \"PingFang SC\", -apple-system, \"Segoe UI\", \"Microsoft YaHei\", sans-serif",
    "serif": "\"Inter\", Georgia, \"Songti SC\", serif",
    "mono": "\"JetBrains Mono\", ui-monospace, \"SF Mono\", Menlo, monospace"
  },
  "text": {
    "xs": "12px",
    "sm": "13px",
    "base": "14px",
    "md": "16px",
    "lg": "20px",
    "xl": "24px",
    "2xl": "32px",
    "3xl": "48px"
  },
  "leading": {
    "tight": "1.2",
    "normal": "1.55",
    "relaxed": "1.75"
  },
  "weight": {
    "normal": "400",
    "medium": "500",
    "bold": "600"
  },
  "tracking": {
    "tight": "-0.02em",
    "normal": "0"
  },
  "shadow": {
    "light": {
      "sm": "0 2px 8px rgba(31,38,89,.08)",
      "md": "0 8px 28px rgba(31,38,89,.14)",
      "lg": "0 20px 56px rgba(31,38,89,.20)",
      "glass-inset": "inset 0 1px 0 rgba(255,255,255,.55)"
    },
    "dark": {
      "sm": "0 2px 8px rgba(0,0,0,.40)",
      "md": "0 8px 28px rgba(0,0,0,.50)",
      "lg": "0 20px 56px rgba(0,0,0,.62)",
      "glass-inset": "inset 0 1px 0 rgba(255,255,255,.18)"
    }
  },
  "glass": {
    "blur": "18px",
    "blur-sm": "12px"
  },
  "z": {
    "dropdown": 1000,
    "sticky": 1100,
    "modal-backdrop": 1200,
    "modal": 1300,
    "toast": 1400,
    "tooltip": 1500
  },
  "motion": {
    "ease": "cubic-bezier(.2,.8,.2,1)",
    "dur-fast": "140ms",
    "dur-base": "220ms",
    "dur-slow": "360ms"
  }
}
