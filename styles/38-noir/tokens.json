{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "noir",
  "description": "Film Noir · 黑色电影 (Cinematic) · 高反差黑白、威尼斯百叶阴影、key-light 径向光与 vignette、场记板 motif、细 grain，以及单一暖色强调里的 smoky amber + crimson neon。",
  "note": "本风格暗为主：默认（:root / data-theme=dark / .dark）即 noir night；亮（high-key paper dossier）模式用 data-theme=light 或 .light 覆盖。",
  "color": {
    "dark": {
      "bg": "#0c0c0e",
      "bg-subtle": "#141416",
      "bg-elevated": "#1a1a1d",
      "bg-sunken": "#060607",
      "fg": "#ece9e2",
      "fg-muted": "#a8a59c",
      "fg-subtle": "#79766d",
      "fg-on-accent": "#1a1206",
      "border": "#2a2a2d",
      "border-strong": "#ece9e2",
      "primary": "#d9a441",
      "primary-hover": "#e6b357",
      "primary-active": "#c8923a",
      "primary-fg": "#1a1206",
      "accent": "#c83a30",
      "accent-fg": "#ffffff",
      "success": "#6aaf6a",
      "success-bg": "#0e220e",
      "success-fg": "#cde6cd",
      "warning": "#d9a441",
      "warning-bg": "#241a06",
      "warning-fg": "#f6e6c2",
      "danger": "#e25a4e",
      "danger-bg": "#2a0c09",
      "danger-fg": "#f8d6d0",
      "info": "#8aa6c0",
      "info-bg": "#0c1a26",
      "info-fg": "#d6e6f2",
      "focus": "#d9a441"
    },
    "light": {
      "bg": "#f2f0ea",
      "bg-subtle": "#e7e4db",
      "bg-elevated": "#fbfaf5",
      "bg-sunken": "#dcd8cd",
      "fg": "#16140f",
      "fg-muted": "#4a463c",
      "fg-subtle": "#6e695c",
      "fg-on-accent": "#ffffff",
      "border": "#cfc9bb",
      "border-strong": "#16140f",
      "primary": "#8a5a14",
      "primary-hover": "#76490f",
      "primary-active": "#5f3b0a",
      "primary-fg": "#ffffff",
      "accent": "#b3302a",
      "accent-fg": "#ffffff",
      "success": "#2f7a3a",
      "success-bg": "#e4f0e2",
      "success-fg": "#103a14",
      "warning": "#8a5a14",
      "warning-bg": "#f4e8cf",
      "warning-fg": "#3e2a08",
      "danger": "#b3302a",
      "danger-bg": "#f6e0dd",
      "danger-fg": "#511210",
      "info": "#3a5a78",
      "info-bg": "#e2e9f0",
      "info-fg": "#11283a",
      "focus": "#8a5a14"
    }
  },
  "radius": {
    "sm": "1px",
    "md": "2px",
    "lg": "4px",
    "full": "9999px"
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "32px",
    "8": "40px",
    "9": "48px",
    "10": "64px",
    "11": "80px",
    "12": "96px"
  },
  "font": {
    "serif": "\"Noto Serif\", Georgia, serif",
    "sans": "\"Inter\",-apple-system,\"PingFang SC\",sans-serif",
    "mono": "\"JetBrains Mono\",monospace"
  },
  "text": {
    "xs": "12px",
    "sm": "13px",
    "base": "15px",
    "md": "18px",
    "lg": "22px",
    "xl": "30px",
    "2xl": "42px",
    "3xl": "60px"
  },
  "leading": {
    "tight": "1.15",
    "normal": "1.5",
    "relaxed": "1.75"
  },
  "weight": {
    "normal": "400",
    "medium": "500",
    "bold": "600"
  },
  "tracking": {
    "tight": "-0.02em",
    "normal": "0"
  },
  "shadow": {
    "dark": {
      "sm": "0 2px 6px rgba(0,0,0,.6)",
      "md": "0 10px 28px -8px rgba(0,0,0,.75)",
      "lg": "0 28px 64px -16px rgba(0,0,0,.85)"
    },
    "light": {
      "sm": "0 1px 2px rgba(22,20,15,.16)",
      "md": "0 8px 22px -8px rgba(22,20,15,.26)",
      "lg": "0 22px 50px -16px rgba(22,20,15,.34)"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.22,.61,.36,1)",
    "dur-fast": "160ms",
    "dur-base": "260ms",
    "dur-slow": "380ms"
  },
  "image": {
    "treatment": "Local photos only; duotone grayscale with filter: grayscale(1) contrast(1.1). Use blinds, key-light radial, vignette, subtle grain, and restrained amber/crimson accents.",
    "container-max": "1120px"
  }
}
