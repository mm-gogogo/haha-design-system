{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "swiss",
  "description": "瑞士国际主义设计系统 Token —— 客观、网格、数学化。中性灰阶 + 黑/白 + 单一红色强调，Neo-grotesque 字型、扁平零圆角、发丝线分隔。",
  "color": {
    "light": {
      "bg": "#ffffff",
      "bg-subtle": "#f4f4f4",
      "bg-elevated": "#ffffff",
      "bg-sunken": "#ededed",
      "fg": "#111111",
      "fg-muted": "#555555",
      "fg-subtle": "#6f6f6f",
      "fg-on-accent": "#ffffff",
      "border": "#e0e0e0",
      "border-strong": "#111111",
      "primary": "#cc1f16",
      "primary-hover": "#b31a12",
      "primary-active": "#991610",
      "primary-fg": "#ffffff",
      "accent": "#cc1f16",
      "accent-fg": "#ffffff",
      "success": "#1a7d3c",
      "success-bg": "#e9f6ed",
      "success-fg": "#0a3d1c",
      "warning": "#8a5a00",
      "warning-bg": "#fbf0d8",
      "warning-fg": "#4a3000",
      "danger": "#cc1f16",
      "danger-bg": "#fbe5e3",
      "danger-fg": "#5e0f0a",
      "info": "#14467a",
      "info-bg": "#e4eef8",
      "info-fg": "#0a2542",
      "focus": "#cc1f16"
    },
    "dark": {
      "bg": "#0a0a0a",
      "bg-subtle": "#141414",
      "bg-elevated": "#161616",
      "bg-sunken": "#000000",
      "fg": "#f2f2f2",
      "fg-muted": "#a6a6a6",
      "fg-subtle": "#8a8a8a",
      "fg-on-accent": "#0a0a0a",
      "border": "#2a2a2a",
      "border-strong": "#f2f2f2",
      "primary": "#ff453a",
      "primary-hover": "#ff6157",
      "primary-active": "#e63b30",
      "primary-fg": "#0a0a0a",
      "accent": "#ff453a",
      "accent-fg": "#0a0a0a",
      "success": "#4cc266",
      "success-bg": "#0c2614",
      "success-fg": "#bdf0cb",
      "warning": "#e0a93d",
      "warning-bg": "#241803",
      "warning-fg": "#f8e4b8",
      "danger": "#ff5b52",
      "danger-bg": "#2a0c0a",
      "danger-fg": "#ffd2ce",
      "info": "#5a9fe0",
      "info-bg": "#0a1f33",
      "info-fg": "#cfe4f8",
      "focus": "#ff453a"
    }
  },
  "focusRing": "0 0 0 2px var(--ds-bg), 0 0 0 4px var(--ds-focus)",
  "radius": {
    "sm": "0px",
    "md": "0px",
    "lg": "0px",
    "full": "9999px"
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "32px",
    "8": "40px",
    "9": "48px",
    "10": "64px",
    "11": "80px",
    "12": "96px"
  },
  "font": {
    "sans": "\"Inter\", \"Helvetica Neue\", Helvetica, Arial, \"PingFang SC\", sans-serif",
    "serif": "\"Source Serif 4\", Georgia, \"Songti SC\", \"SimSun\", serif",
    "mono": "\"JetBrains Mono\", ui-monospace, \"SF Mono\", Menlo, Consolas, monospace"
  },
  "text": {
    "xs": "12px",
    "sm": "13px",
    "base": "14px",
    "md": "16px",
    "lg": "20px",
    "xl": "24px",
    "2xl": "32px",
    "3xl": "48px"
  },
  "leading": {
    "tight": "1.2",
    "normal": "1.5",
    "relaxed": "1.7"
  },
  "weight": {
    "normal": "400",
    "medium": "500",
    "bold": "600"
  },
  "tracking": {
    "tight": "-0.02em",
    "normal": "0"
  },
  "shadow": {
    "light": {
      "sm": "0 0 0 1px var(--ds-border)",
      "md": "0 0 0 1px var(--ds-border)",
      "lg": "0 0 0 1px var(--ds-border-strong)"
    },
    "dark": {
      "sm": "0 0 0 1px var(--ds-border)",
      "md": "0 0 0 1px var(--ds-border)",
      "lg": "0 0 0 1px var(--ds-border-strong)"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.22,.61,.36,1)",
    "dur-fast": "150ms",
    "dur-base": "200ms",
    "dur-slow": "250ms"
  }
}
