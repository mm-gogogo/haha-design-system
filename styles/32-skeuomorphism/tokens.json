{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "skeuomorphism",
  "description": "Skeuomorphism · 拟物写实 (Rich Skeuo) uses warm linen, stitched leather, felt, brushed metal, glossy gel controls, letterpress text, bevels, and layered realistic shadows for tactile desk and journal apps.",
  "color": {
    "light": {
      "bg": "#e7ddc9",
      "bg-subtle": "#dccfb5",
      "bg-elevated": "#fbf6ea",
      "bg-sunken": "#d0c2a4",
      "fg": "#2c2419",
      "fg-muted": "#5a4d38",
      "fg-subtle": "#786a4e",
      "fg-on-accent": "#ffffff",
      "border": "#cbbb98",
      "border-strong": "#2c2419",
      "primary": "#2f6fd0",
      "primary-hover": "#2860b8",
      "primary-active": "#21509c",
      "primary-fg": "#ffffff",
      "accent": "#8a6a1e",
      "accent-fg": "#fff8ec",
      "success": "#3a7a3a",
      "success-bg": "#e6f1e2",
      "success-fg": "#123a12",
      "warning": "#9a6a14",
      "warning-bg": "#f6ead0",
      "warning-fg": "#43300a",
      "danger": "#b03a2e",
      "danger-bg": "#f7e2de",
      "danger-fg": "#551410",
      "info": "#2f6fd0",
      "info-bg": "#e3ecf8",
      "info-fg": "#0e2c5a",
      "focus": "#2f6fd0"
    },
    "dark": {
      "bg": "#1f1a12",
      "bg-subtle": "#261f15",
      "bg-elevated": "#2c2419",
      "bg-sunken": "#14100a",
      "fg": "#efe6d2",
      "fg-muted": "#b6a98c",
      "fg-subtle": "#847862",
      "fg-on-accent": "#08142e",
      "border": "#3a3122",
      "border-strong": "#c9a86a",
      "primary": "#5d97f0",
      "primary-hover": "#74a8f4",
      "primary-active": "#4d86e0",
      "primary-fg": "#08142e",
      "accent": "#c9a259",
      "accent-fg": "#1a1408",
      "success": "#6fbf6f",
      "success-bg": "#102a10",
      "success-fg": "#cdeec0",
      "warning": "#e0b35a",
      "warning-bg": "#241a06",
      "warning-fg": "#f6e6be",
      "danger": "#e07a5f",
      "danger-bg": "#2a0f08",
      "danger-fg": "#f8d6c8",
      "info": "#5d97f0",
      "info-bg": "#0c1c3a",
      "info-fg": "#d6e4fb",
      "focus": "#5d97f0"
    }
  },
  "radius": {
    "sm": "6px",
    "md": "12px",
    "lg": "18px",
    "full": "9999px"
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "32px",
    "8": "40px",
    "9": "48px",
    "10": "64px",
    "11": "80px",
    "12": "96px"
  },
  "font": {
    "sans": "'Inter',-apple-system,'PingFang SC',sans-serif",
    "serif": "'Noto Serif', Georgia, serif",
    "mono": "'JetBrains Mono',monospace"
  },
  "text": {
    "xs": "12px",
    "sm": "13px",
    "base": "14px",
    "md": "16px",
    "lg": "20px",
    "xl": "24px",
    "2xl": "32px",
    "3xl": "48px"
  },
  "leading": {
    "tight": "1.25",
    "normal": "1.55",
    "relaxed": "1.75"
  },
  "weight": {
    "normal": "400",
    "medium": "500",
    "bold": "600"
  },
  "tracking": {
    "tight": "-0.01em",
    "normal": "0"
  },
  "shadow": {
    "light": {
      "sm": "inset 0 1px 0 rgba(255,255,255,.55), 0 1px 2px rgba(44,36,25,.28)",
      "md": "inset 0 1px 0 rgba(255,255,255,.5), 0 4px 10px -2px rgba(44,36,25,.3)",
      "lg": "inset 0 1px 0 rgba(255,255,255,.5), 0 12px 28px -6px rgba(44,36,25,.4)",
      "inset": "inset 0 2px 4px rgba(44,36,25,.38), inset 0 -1px 0 rgba(255,255,255,.35)",
      "inset-sm": "inset 0 1px 2px rgba(44,36,25,.32), inset 0 -1px 0 rgba(255,255,255,.32)"
    },
    "dark": {
      "sm": "inset 0 1px 0 rgba(255,255,255,.08), 0 1px 2px rgba(0,0,0,.55)",
      "md": "inset 0 1px 0 rgba(255,255,255,.07), 0 5px 12px -2px rgba(0,0,0,.6)",
      "lg": "inset 0 1px 0 rgba(255,255,255,.06), 0 14px 30px -6px rgba(0,0,0,.7)",
      "inset": "inset 0 2px 5px rgba(0,0,0,.72), inset 0 -1px 0 rgba(255,255,255,.06)",
      "inset-sm": "inset 0 1px 3px rgba(0,0,0,.68), inset 0 -1px 0 rgba(255,255,255,.05)"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.25,.46,.45,.94)",
    "dur-fast": "200ms",
    "dur-base": "240ms",
    "dur-slow": "280ms"
  }
}
