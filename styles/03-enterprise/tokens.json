{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "enterprise",
  "description": "企业风设计系统 Token —— 稳重、专业、可信赖、克制。商务蓝主调，Geist 语义骨架。",
  "color": {
    "light": {
      "bg": "#ffffff",
      "bg-subtle": "#f7f9fc",
      "bg-elevated": "#ffffff",
      "bg-sunken": "#eef2f7",
      "fg": "#0f172a",
      "fg-muted": "#475569",
      "fg-subtle": "#64748b",
      "fg-on-accent": "#ffffff",
      "border": "#e2e8f0",
      "border-strong": "#cbd5e1",
      "primary": "#2563eb",
      "primary-hover": "#1d4ed8",
      "primary-active": "#1e40af",
      "primary-fg": "#ffffff",
      "accent": "#0e7490",
      "accent-fg": "#ffffff",
      "success": "#16a34a",
      "success-bg": "#ecfdf3",
      "success-fg": "#06401f",
      "warning": "#d97706",
      "warning-bg": "#fffaeb",
      "warning-fg": "#6b3b00",
      "danger": "#dc2626",
      "danger-bg": "#fef2f2",
      "danger-fg": "#6b0e0e",
      "info": "#2563eb",
      "info-bg": "#eff6ff",
      "info-fg": "#0b357a",
      "focus": "#2563eb"
    },
    "dark": {
      "bg": "#0b1220",
      "bg-subtle": "#0f1729",
      "bg-elevated": "#131c30",
      "bg-sunken": "#080d18",
      "fg": "#e8eef7",
      "fg-muted": "#9fb0c8",
      "fg-subtle": "#7888a3",
      "fg-on-accent": "#ffffff",
      "border": "#1f2c45",
      "border-strong": "#314465",
      "primary": "#3b82f6",
      "primary-hover": "#60a5fa",
      "primary-active": "#2563eb",
      "primary-fg": "#08111f",
      "accent": "#22d3ee",
      "accent-fg": "#08111f",
      "success": "#34d399",
      "success-bg": "#0a2417",
      "success-fg": "#c4f5dd",
      "warning": "#fbbf24",
      "warning-bg": "#2a1d05",
      "warning-fg": "#fdeec2",
      "danger": "#f87171",
      "danger-bg": "#2c1012",
      "danger-fg": "#ffd9d9",
      "info": "#60a5fa",
      "info-bg": "#0d1f3d",
      "info-fg": "#d6e6ff",
      "focus": "#3b82f6"
    }
  },
  "focusRing": "0 0 0 2px var(--ds-bg), 0 0 0 4px var(--ds-focus)",
  "radius": {
    "sm": "6px",
    "md": "10px",
    "lg": "16px",
    "full": "9999px"
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "32px",
    "8": "40px",
    "9": "48px",
    "10": "64px",
    "11": "80px",
    "12": "96px"
  },
  "font": {
    "sans": "\"Inter\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", \"PingFang SC\", \"Microsoft YaHei\", \"Hiragino Sans GB\", sans-serif",
    "serif": "\"Source Serif 4\", Georgia, \"Songti SC\", \"SimSun\", serif",
    "mono": "\"JetBrains Mono\", ui-monospace, \"SF Mono\", Menlo, Consolas, monospace"
  },
  "text": {
    "xs": "12px",
    "sm": "13px",
    "base": "14px",
    "md": "16px",
    "lg": "20px",
    "xl": "24px",
    "2xl": "32px",
    "3xl": "48px"
  },
  "leading": {
    "tight": "1.2",
    "normal": "1.5",
    "relaxed": "1.7"
  },
  "weight": {
    "normal": "400",
    "medium": "500",
    "bold": "600"
  },
  "tracking": {
    "tight": "-0.01em",
    "normal": "0"
  },
  "shadow": {
    "light": {
      "sm": "0 1px 2px rgba(16,24,40,.06)",
      "md": "0 1px 2px rgba(16,24,40,.04), 0 4px 8px -2px rgba(16,24,40,.06), 0 12px 20px -8px rgba(16,24,40,.08)",
      "lg": "0 1px 2px rgba(16,24,40,.04), 0 8px 16px -4px rgba(16,24,40,.08), 0 24px 40px -12px rgba(16,24,40,.12)"
    },
    "dark": {
      "sm": "0 1px 2px rgba(0,0,0,.5)",
      "md": "0 4px 8px -2px rgba(0,0,0,.55), 0 12px 24px -8px rgba(0,0,0,.65)",
      "lg": "0 8px 16px -4px rgba(0,0,0,.6), 0 24px 40px -12px rgba(0,0,0,.75)"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.22,.61,.36,1)",
    "dur-fast": "150ms",
    "dur-base": "200ms",
    "dur-slow": "250ms"
  }
}
