    "light": {
      "sm": "0 1px 2px rgba(120,40,90,.1)",
      "md": "0 8px 24px -10px rgba(120,40,90,.2)",
      "lg": "0 16px 40px -14px rgba(120,40,90,.26)"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.2,.8,.2,1)",
    "dur-fast": "150ms",
    "dur-base": "200ms",
    "dur-slow": "260ms"
  }
