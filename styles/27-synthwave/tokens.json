      "bg-sunken": "#f0d9ea",
      "fg": "#2a1535",
      "fg-muted": "#6a4a78",
      "fg-subtle": "#8a6a98",
      "fg-on-accent": "#ffffff",
      "border": "#f0cfe4",
      "border-strong": "#c44a9a",
      "primary": "#c01f72",
      "primary-hover": "#a81a65",
      "primary-active": "#8f1556",
      "primary-fg": "#ffffff",
      "accent": "#0d6f7e",
      "accent-fg": "#ffffff",
      "success": "#1f8a5a", "success-bg": "#e2f4ec", "success-fg": "#0a3a26",
      "warning": "#9a6a00", "warning-bg": "#f6eccf", "warning-fg": "#473006",
      "danger": "#c01f3a", "danger-bg": "#f9e0e4", "danger-fg": "#5a0f1c",
      "info": "#1f6f9a", "info-bg": "#e2eef6", "info-fg": "#0c2c40",
      "focus": "#c01f72"
    }
  },
  "focusRing": {
    "dark": "0 0 0 2px #150a2a,0 0 0 4px #ff5fa2,0 0 16px -2px rgba(255,95,162,.6)",
    "light": "0 0 0 2px #fdf2f8,0 0 0 4px #c01f72,0 0 10px -3px rgba(192,31,114,.36)"
  },
  "radius": {
    "sm": "2px",
    "md": "6px",
    "lg": "10px",
    "full": "9999px"
  },
  "space": {
    "1": "4px", "2": "8px", "3": "12px", "4": "16px",
    "5": "20px", "6": "24px", "7": "32px", "8": "40px",
    "9": "48px", "10": "64px", "11": "80px", "12": "96px"
  },
  "font": {
    "sans": "\"Inter\",-apple-system,\"PingFang SC\",sans-serif",
    "serif": "\"Inter\",Georgia,\"Songti SC\",serif",
    "mono": "\"JetBrains Mono\",monospace"
  },
  "fontSize": {
    "xs": "12px", "sm": "13px", "base": "14px", "md": "16px",
    "lg": "20px", "xl": "24px", "2xl": "32px", "3xl": "48px"
  },
  "leading": {
    "tight": "1.2",
    "normal": "1.5",
    "relaxed": "1.7"
  },
  "weight": {
    "normal": "400",
    "medium": "500",
    "bold": "600"
  },
  "tracking": {
    "tight": "-0.04em",
    "normal": "0"
  },
  "shadow": {
    "dark": {
      "sm": "0 0 0 1px #3a2470,0 2px 10px -4px rgba(255,95,162,.3)",
      "md": "0 0 0 1px #3a2470,0 8px 28px -10px rgba(0,0,0,.7),0 0 24px -8px rgba(41,224,224,.3)",
      "lg": "0 0 0 1px #3a2470,0 16px 48px -14px rgba(0,0,0,.8),0 0 40px -10px rgba(255,95,162,.4)"
