{
  "$meta": {
    "name": "Synthwave / 蒸汽波 / 合成波（Outrun）",
    "description": "暗色优先的 80s retro-future 设计系统。日落 magenta→purple→cyan/orange、透视网格地平线、复古条纹太阳、chrome/outline display 字、低透明扫描线与克制霓虹辉光。注意 :root=暗色，[data-theme=\"light\"]/.light 为 Miami pastel day 亮色覆盖。",
    "version": "1.0.0",
    "contract": "ds-token-contract@1",
    "themeStrategy": "dark-first",
    "base": "dark",
    "override": "light"
  },
  "color": {
    "dark": {
      "bg": "#150a2a",
      "bg-subtle": "#1d0f38",
      "bg-elevated": "#251444",
      "bg-sunken": "#0e0620",
      "fg": "#f4ecff",
      "fg-muted": "#b9a8e0",
      "fg-subtle": "#8a76c0",
      "fg-on-accent": "#1a0820",
      "border": "#3a2470",
      "border-strong": "#6a4ac0",
      "primary": "#ff5fa2",
      "primary-hover": "#ff7db5",
      "primary-active": "#ee4a90",
      "primary-fg": "#1a0820",
      "accent": "#29e0e0",
      "accent-fg": "#042020",
      "success": "#3fd58f", "success-bg": "#06281c", "success-fg": "#c9f5dd",
      "warning": "#ffc24d", "warning-bg": "#241803", "warning-fg": "#fff0c0",
      "danger": "#ff5c72", "danger-bg": "#2a0c14", "danger-fg": "#ffd0d8",
