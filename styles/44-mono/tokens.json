{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "mono",
  "description": "Stark Mono 极简黑白设计系统 Token —— gallery white + true black, accentless grayscale discipline, dramatic display type, 1px hairline rules, generous whitespace, and restrained semantic status colors only.",
  "color": {
    "light": {
      "bg": "#ffffff",
      "bg-subtle": "#f4f4f5",
      "bg-elevated": "#ffffff",
      "bg-sunken": "#e9e9eb",
      "fg": "#0a0a0a",
      "fg-muted": "#52525b",
      "fg-subtle": "#71717a",
      "fg-on-accent": "#ffffff",
      "border": "#e4e4e7",
      "border-strong": "#0a0a0a",
      "primary": "#0a0a0a",
      "primary-hover": "#27272a",
      "primary-active": "#000000",
      "primary-fg": "#ffffff",
      "accent": "#3f3f46",
      "accent-fg": "#ffffff",
      "success": "#2f7d46",
      "success-bg": "#eaf2ec",
      "success-fg": "#11371f",
      "warning": "#8a6300",
      "warning-bg": "#f4ecd6",
      "warning-fg": "#3e2d00",
      "danger": "#c4302a",
      "danger-bg": "#f7e3e1",
      "danger-fg": "#551310",
      "info": "#2257cc",
      "info-bg": "#e6ecfa",
      "info-fg": "#0c2356",
      "focus": "#0a0a0a"
    },
    "dark": {
      "bg": "#000000",
      "bg-subtle": "#0c0c0e",
      "bg-elevated": "#161618",
      "bg-sunken": "#000000",
      "fg": "#fafafa",
      "fg-muted": "#a1a1aa",
      "fg-subtle": "#71717a",
      "fg-on-accent": "#0a0a0a",
      "border": "#27272a",
      "border-strong": "#fafafa",
      "primary": "#fafafa",
      "primary-hover": "#e4e4e7",
      "primary-active": "#ffffff",
      "primary-fg": "#0a0a0a",
      "accent": "#a1a1aa",
      "accent-fg": "#0a0a0a",
      "success": "#4ec06a",
      "success-bg": "#0c2614",
      "success-fg": "#cdeccf",
      "warning": "#e0b250",
      "warning-bg": "#241a06",
      "warning-fg": "#f6e6be",
      "danger": "#f0584e",
      "danger-bg": "#2a0c0a",
      "danger-fg": "#ffd6d2",
      "info": "#5b8cf0",
      "info-bg": "#0a1630",
      "info-fg": "#d6e2fb",
      "focus": "#fafafa"
    }
  },
  "focusRing": "0 0 0 2px var(--ds-bg), 0 0 0 4px var(--ds-focus)",
  "radius": {
    "sm": "2px",
    "md": "4px",
    "lg": "8px",
    "full": "9999px"
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "32px",
    "8": "40px",
    "9": "48px",
    "10": "64px",
    "11": "80px",
    "12": "96px"
  },
  "font": {
    "sans": "\"Inter\", -apple-system, \"PingFang SC\", sans-serif",
    "serif": "\"Noto Serif\", Georgia, \"Songti SC\", serif",
    "mono": "\"JetBrains Mono\", monospace"
  },
  "text": {
    "xs": "12px",
    "sm": "13px",
    "base": "14px",
    "md": "16px",
    "lg": "22px",
    "xl": "28px",
    "2xl": "40px",
    "3xl": "64px"
  },
  "leading": {
    "tight": "1.12",
    "normal": "1.5",
    "relaxed": "1.72"
  },
  "weight": {
    "normal": "400",
    "medium": "600",
    "bold": "800"
  },
  "tracking": {
    "tight": "-0.03em",
    "normal": "0"
  },
  "shadow": {
    "light": {
      "sm": "0 0 0 1px var(--ds-border)",
      "md": "0 1px 2px rgba(10,10,10,.08)",
      "lg": "0 8px 24px -10px rgba(10,10,10,.16)"
    },
    "dark": {
      "sm": "0 0 0 1px var(--ds-border)",
      "md": "0 1px 2px rgba(0,0,0,.5)",
      "lg": "0 8px 24px -10px rgba(0,0,0,.6)"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.22,.61,.36,1)",
    "dur-fast": "150ms",
    "dur-base": "200ms",
    "dur-slow": "250ms"
  }
}
