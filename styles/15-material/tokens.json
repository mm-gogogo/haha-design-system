{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "material",
  "description": "Material Design (M3) 设计系统 Token —— 鲜明扁平色块、tonal surface、清晰 elevation 分层、圆角 + FAB/chip。Geist 语义骨架。",
  "color": {
    "light": {
      "bg": "#fef7ff",
      "bg-subtle": "#e7e0ec",
      "bg-elevated": "#faf2fb",
      "bg-sunken": "#e7e0ec",
      "fg": "#1d1b20",
      "fg-muted": "#49454f",
      "fg-subtle": "#5f5a66",
      "fg-on-accent": "#ffffff",
      "border": "#cac4d0",
      "border-strong": "#79747e",
      "primary": "#6750a4",
      "primary-hover": "#5a4592",
      "primary-active": "#4e3a82",
      "primary-fg": "#ffffff",
      "accent": "#7d5260",
      "accent-fg": "#ffffff",
      "success": "#1e6b3a",
      "success-bg": "#e6f4ea",
      "success-fg": "#0c3a20",
      "warning": "#7a5200",
      "warning-bg": "#fdf2da",
      "warning-fg": "#5b3d00",
      "danger": "#b3261e",
      "danger-bg": "#fce9e8",
      "danger-fg": "#5c0e0a",
      "info": "#5b4790",
      "info-bg": "#ebe4f9",
      "info-fg": "#2a2152",
      "focus": "#6750a4"
    },
    "dark": {
      "bg": "#141218",
      "bg-subtle": "#2b2930",
      "bg-elevated": "#211f26",
      "bg-sunken": "#1d1b20",
      "fg": "#e6e0e9",
      "fg-muted": "#cac4d0",
      "fg-subtle": "#988f9b",
      "fg-on-accent": "#ffffff",
      "border": "#48454e",
      "border-strong": "#948f99",
      "primary": "#d0bcff",
      "primary-hover": "#ddccff",
      "primary-active": "#b69df8",
      "primary-fg": "#381e72",
      "accent": "#efb8c8",
      "accent-fg": "#492532",
      "success": "#7ddc9e",
      "success-bg": "#0f2a1a",
      "success-fg": "#c6f0d4",
      "warning": "#f3c969",
      "warning-bg": "#2a1f05",
      "warning-fg": "#fbe7b3",
      "danger": "#f2b8b5",
      "danger-bg": "#2a1110",
      "danger-fg": "#ffdad6",
      "info": "#cfbcfb",
      "info-bg": "#1c142e",
      "info-fg": "#e7deff",
      "focus": "#d0bcff"
    }
  },
  "focusRing": "0 0 0 2px var(--ds-bg), 0 0 0 4px var(--ds-focus)",
  "radius": {
    "sm": "8px",
    "md": "12px",
    "lg": "16px",
    "full": "9999px"
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "32px",
    "8": "40px",
    "9": "48px",
    "10": "64px",
    "11": "80px",
    "12": "96px"
  },
  "font": {
    "sans": "\"Inter\", \"Roboto\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", \"PingFang SC\", \"Microsoft YaHei\", \"Hiragino Sans GB\", sans-serif",
    "serif": "\"Noto Serif\", Georgia, \"Songti SC\", \"SimSun\", serif",
    "mono": "\"JetBrains Mono\", ui-monospace, \"SF Mono\", Menlo, Consolas, monospace"
  },
  "text": {
    "xs": "12px",
    "sm": "13px",
    "base": "14px",
    "md": "16px",
    "lg": "20px",
    "xl": "24px",
    "2xl": "32px",
    "3xl": "48px"
  },
  "leading": {
    "tight": "1.2",
    "normal": "1.5",
    "relaxed": "1.7"
  },
  "weight": {
    "normal": "400",
    "medium": "500",
    "bold": "600"
  },
  "tracking": {
    "tight": "-0.02em",
    "normal": "0"
  },
  "shadow": {
    "light": {
      "sm": "0 1px 2px rgba(0,0,0,.30), 0 1px 3px 1px rgba(0,0,0,.15)",
      "md": "0 1px 2px rgba(0,0,0,.30), 0 2px 6px 2px rgba(0,0,0,.15)",
      "lg": "0 4px 8px 3px rgba(0,0,0,.15), 0 1px 3px rgba(0,0,0,.30)"
    },
    "dark": {
      "sm": "0 1px 2px rgba(0,0,0,.55), 0 1px 3px 1px rgba(0,0,0,.45)",
      "md": "0 1px 2px rgba(0,0,0,.55), 0 2px 6px 2px rgba(0,0,0,.45)",
      "lg": "0 4px 8px 3px rgba(0,0,0,.45), 0 1px 3px rgba(0,0,0,.6)"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.2,0,0,1)",
    "dur-fast": "150ms",
    "dur-base": "250ms",
    "dur-slow": "400ms"
  }
}
