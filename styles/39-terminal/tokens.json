{
  "$meta": {
    "name": "Terminal / TUI 终端绿磷",
    "description": "暗色优先的 vintage computer terminal / TUI 设计系统。绿磷 CRT、琥珀 ANSI 次强调、全等宽字体、硬边 ASCII 框、状态行与扫描线。",
    "version": "1.0.0",
    "contract": "ds-token-contract@1",
    "themeStrategy": "dark-first",
    "base": "dark",
    "override": "light"
  },
  "color": {
    "dark": {
      "bg": "#050a06",
      "bg-subtle": "#0a140c",
      "bg-elevated": "#0e1a10",
      "bg-sunken": "#020503",
      "fg": "#c8f5d2",
      "fg-muted": "#7fb890",
      "fg-subtle": "#5a8568",
      "fg-on-accent": "#04140a",
      "border": "#1c3322",
      "border-strong": "#2ee06a",
      "primary": "#2ee06a",
      "primary-hover": "#4af07f",
      "primary-active": "#25c85a",
      "primary-fg": "#04140a",
      "accent": "#ffb000",
      "accent-fg": "#1a1200",
      "success": "#2ee06a", "success-bg": "#06200f", "success-fg": "#bff5cd",
      "warning": "#ffb000", "warning-bg": "#241800", "warning-fg": "#ffe6b0",
      "danger": "#ff5f56", "danger-bg": "#260a08", "danger-fg": "#ffd2ce",
      "info": "#56d4ff", "info-bg": "#06202a", "info-fg": "#cdeeff",
      "focus": "#2ee06a"
    },
    "light": {
      "bg": "#eef2ec",
      "bg-subtle": "#e2e8df",
      "bg-elevated": "#f7faf4",
      "bg-sunken": "#d8e0d4",
      "fg": "#0e2014",
      "fg-muted": "#3f5a48",
      "fg-subtle": "#5f7a68",
      "fg-on-accent": "#ffffff",
      "border": "#c8d4c6",
      "border-strong": "#0e2014",
      "primary": "#157a3e",
      "primary-hover": "#126a36",
      "primary-active": "#0f5a2e",
      "primary-fg": "#ffffff",
      "accent": "#8a5a00",
      "accent-fg": "#ffffff",
      "success": "#157a3e", "success-bg": "#e2f0e6", "success-fg": "#0a3a1e",
      "warning": "#8a5a00", "warning-bg": "#f4ecd2", "warning-fg": "#3e2a00",
      "danger": "#b3302a", "danger-bg": "#f6e0dd", "danger-fg": "#511210",
      "info": "#1f5f8a", "info-bg": "#e2edf4", "info-fg": "#0c2a3e",
      "focus": "#157a3e"
    }
  },
  "focusRing": {
    "dark": "0 0 0 2px #050a06, 0 0 0 4px #2ee06a",
    "light": "0 0 0 2px #eef2ec, 0 0 0 4px #157a3e"
  },
  "radius": {
    "sm": "0px",
    "md": "0px",
    "lg": "2px",
    "full": "9999px"
  },
  "space": {
    "1": "4px", "2": "8px", "3": "12px", "4": "16px",
    "5": "20px", "6": "24px", "7": "32px", "8": "40px",
    "9": "48px", "10": "64px", "11": "80px", "12": "96px"
  },
  "font": {
    "sans": "\"JetBrains Mono\", ui-monospace, monospace",
    "serif": "\"JetBrains Mono\", ui-monospace, monospace",
    "mono": "\"JetBrains Mono\", ui-monospace, monospace"
  },
  "fontSize": {
    "xs": "12px", "sm": "13px", "base": "14px", "md": "16px",
    "lg": "20px", "xl": "24px", "2xl": "32px", "3xl": "48px"
  },
  "leading": {
    "tight": "1.2",
    "normal": "1.5",
    "relaxed": "1.7"
  },
  "weight": {
    "normal": "400",
    "medium": "500",
    "bold": "600"
  },
  "tracking": {
    "tight": "-0.02em",
    "normal": "0"
  },
  "shadow": {
    "dark": {
      "sm": "0 0 0 1px #1c3322",
      "md": "0 0 0 1px #2ee06a",
      "lg": "0 0 0 1px #2ee06a, 0 0 24px -6px rgba(46,224,106,.4)"
    },
    "light": {
      "sm": "0 0 0 1px #c8d4c6",
      "md": "0 0 0 1px #0e2014",
      "lg": "0 0 0 1px #0e2014"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.2,.8,.2,1)",
    "dur-fast": "150ms",
    "dur-base": "200ms",
    "dur-slow": "250ms"
  }
}
