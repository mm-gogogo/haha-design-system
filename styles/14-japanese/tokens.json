  "motion": {
    "ease": "cubic-bezier(.22,.61,.36,1)",
    "dur-fast": "160ms",
    "dur-base": "240ms",
    "dur-slow": "320ms"
  },
  "image": {
    "radius": "8px",
    "border": "1px solid var(--ds-border)",
    "note": "图片处理：自然光照片 + 米白细边框（1px var(--ds-border)）+ 小圆角（8px）+ 几乎无阴影；克制留白。"
