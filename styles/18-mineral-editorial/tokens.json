      "sm": "0 1px 2px rgba(0,0,0,.4)",
      "md": "0 2px 4px rgba(0,0,0,.4), 0 12px 28px -12px rgba(0,0,0,.55)",
      "lg": "0 4px 8px rgba(0,0,0,.4), 0 22px 48px -16px rgba(0,0,0,.6)"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.22,.61,.36,1)",
    "dur-fast": "160ms",
    "dur-base": "240ms",
    "dur-slow": "300ms"
  },
  "reading": {
    "container-max": "680px",
    "note": "编辑容器 max-width 约 40rem/680px；大标题用衬线、text-wrap balance、字距略紧；正文走人文无衬线、text-wrap pretty、大行高。"
  }
