  "weight": {
    "normal": "400",
    "medium": "500",
    "bold": "600"
  },
  "tracking": {
    "tight": "-0.015em",
    "normal": "0"
  },
  "shadow": {
    "light": {
      "sm": "0 1px 2px rgba(60,50,30,.05)",
      "md": "0 1px 2px rgba(60,50,30,.04), 0 10px 24px -12px rgba(60,50,30,.14)",
      "lg": "0 2px 4px rgba(60,50,30,.05), 0 20px 44px -16px rgba(60,50,30,.18)"
