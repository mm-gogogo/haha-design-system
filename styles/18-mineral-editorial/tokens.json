  "font": {
    "serif": "\"Noto Serif\", Georgia, \"Songti SC\", serif",
    "sans": "\"Inter\", -apple-system, \"PingFang SC\", sans-serif",
    "mono": "\"JetBrains Mono\", ui-monospace, monospace"
  },
  "text": {
    "xs": "13px",
    "sm": "14px",
    "base": "17px",
    "md": "19px",
    "lg": "22px",
    "xl": "28px",
    "2xl": "38px",
    "3xl": "52px"
