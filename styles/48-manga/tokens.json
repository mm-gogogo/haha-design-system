      "sm": "2px 2px 0 var(--ds-border-strong)",
      "md": "4px 4px 0 var(--ds-border-strong)",
      "lg": "7px 7px 0 var(--ds-border-strong)"
    },
    "dark": {
      "sm": "2px 2px 0 var(--ds-border-strong)",
      "md": "4px 4px 0 var(--ds-border-strong)",
      "lg": "7px 7px 0 var(--ds-border-strong)"
