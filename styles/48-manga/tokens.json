    "sm": "0",
    "md": "2px",
    "lg": "4px",
    "full": "999px"
  },
  "space": {
    "1": "4px", "2": "8px", "3": "12px", "4": "16px",
    "5": "20px", "6": "24px", "7": "32px", "8": "40px",
    "9": "48px", "10": "64px", "11": "80px", "12": "96px"
  },
  "font": {
    "sans": "\"Inter\", -apple-system, \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
    "serif": "\"Noto Serif\", \"Noto Serif CJK SC\", \"Source Han Serif SC\", \"Songti SC\", serif",
    "mono": "\"JetBrains Mono\", ui-monospace, \"SF Mono\", Menlo, monospace"
  },
  "fontSize": {
    "xs": "12px", "sm": "14px", "base": "16px", "md": "19px",
