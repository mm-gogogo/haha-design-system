{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "neumorphism",
  "description": "🫧 新拟物风 · 同色基底 + 双向软阴影造软塑料凸凹，柔和触感、平静高级，给桌面工具 / 音乐健康 / 控制面板 / 单窗应用。",
  "color": {
    "light": {
      "bg": "#e8ebf0",
      "bg-subtle": "#e4e7ec",
      "bg-elevated": "#e8ebf0",
      "bg-sunken": "#e0e3e9",
      "fg": "#3a4252",
      "fg-muted": "#5b6273",
      "fg-subtle": "#6b7280",
      "fg-on-accent": "#ffffff",
      "border": "#d2d6de",
      "border-strong": "#bcc2cd",
      "primary": "#4a6fc4",
      "primary-hover": "#3f63b4",
      "primary-active": "#36569e",
      "primary-fg": "#ffffff",
      "accent": "#6f5fd6",
      "accent-fg": "#ffffff",
      "success": "#2f9b6b",
      "success-bg": "#dceee6",
      "success-fg": "#0f5639",
      "warning": "#b97e1f",
      "warning-bg": "#f3e8d2",
      "warning-fg": "#6e480a",
      "danger": "#cf4b4b",
      "danger-bg": "#f3dede",
      "danger-fg": "#7c1d1d",
      "info": "#4a6fc4",
      "info-bg": "#dce4f3",
      "info-fg": "#213a73",
      "focus": "#4a6fc4"
    },
    "dark": {
      "bg": "#2a2d35",
      "bg-subtle": "#272a31",
      "bg-elevated": "#2a2d35",
      "bg-sunken": "#25282f",
      "fg": "#d8dce4",
      "fg-muted": "#a3a9b5",
      "fg-subtle": "#9097a3",
      "fg-on-accent": "#ffffff",
      "border": "#3a3e48",
      "border-strong": "#4a4f5b",
      "primary": "#6e9bff",
      "primary-hover": "#5e8df5",
      "primary-active": "#4f7fe8",
      "primary-fg": "#0c1733",
      "accent": "#a394ff",
      "accent-fg": "#150f33",
      "success": "#54c595",
      "success-bg": "#16352a",
      "success-fg": "#c6f3df",
      "warning": "#e0a23b",
      "warning-bg": "#38290f",
      "warning-fg": "#fbe7c2",
      "danger": "#e87b7b",
      "danger-bg": "#3a2022",
      "danger-fg": "#fad9d9",
      "info": "#6e9bff",
      "info-bg": "#18233f",
      "info-fg": "#d3e0fb",
      "focus": "#6e9bff"
    }
  },
  "radius": {
    "sm": "10px",
    "md": "16px",
    "lg": "24px",
    "full": "9999px"
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "32px",
    "8": "40px",
    "9": "48px",
    "10": "64px",
    "11": "80px",
    "12": "96px"
  },
  "font": {
    "sans": "\"Inter\", \"PingFang SC\", -apple-system, \"Segoe UI\", \"Microsoft YaHei\", sans-serif",
    "serif": "\"Inter\", Georgia, \"Songti SC\", serif",
    "mono": "\"SF Mono\", ui-monospace, Menlo, \"Cascadia Code\", monospace"
  },
  "text": {
    "xs": "12px",
    "sm": "13px",
    "base": "14px",
    "md": "16px",
    "lg": "20px",
    "xl": "24px",
    "2xl": "32px",
    "3xl": "48px"
  },
  "leading": {
    "tight": "1.25",
    "normal": "1.55",
    "relaxed": "1.75"
  },
  "weight": {
    "normal": "400",
    "medium": "500",
    "bold": "600"
  },
  "tracking": {
    "tight": "-0.01em",
    "normal": "0"
  },
  "shadow": {
    "light": {
      "sm": "-3px -3px 6px rgba(255,255,255,.7), 3px 3px 6px rgba(163,177,198,.45)",
      "md": "-6px -6px 12px rgba(255,255,255,.8), 6px 6px 12px rgba(163,177,198,.5)",
      "lg": "-10px -10px 20px rgba(255,255,255,.85), 10px 10px 20px rgba(163,177,198,.55)",
      "inset": "inset 4px 4px 8px rgba(163,177,198,.5), inset -4px -4px 8px rgba(255,255,255,.8)",
      "inset-sm": "inset 2px 2px 5px rgba(163,177,198,.45), inset -2px -2px 5px rgba(255,255,255,.75)"
    },
    "dark": {
      "sm": "-3px -3px 6px rgba(60,66,80,.55), 3px 3px 6px rgba(0,0,0,.55)",
      "md": "-6px -6px 12px rgba(60,66,80,.6), 6px 6px 12px rgba(0,0,0,.6)",
      "lg": "-10px -10px 20px rgba(60,66,80,.6), 10px 10px 20px rgba(0,0,0,.65)",
      "inset": "inset 4px 4px 8px rgba(0,0,0,.6), inset -4px -4px 8px rgba(60,66,80,.55)",
      "inset-sm": "inset 2px 2px 5px rgba(0,0,0,.55), inset -2px -2px 5px rgba(60,66,80,.5)"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.25,.46,.45,.94)",
    "dur-fast": "200ms",
    "dur-base": "240ms",
    "dur-slow": "280ms"
  }
}
