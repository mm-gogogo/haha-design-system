{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "art-nouveau",
  "description": "Art Nouveau / 新艺术运动植物香氛温室 · 暖羊皮纸基底、鼠尾草青绿主操作、哑金细线、sepia 墨色文字、鸢尾/百合/藤蔓线稿与拱形装饰框。给植物香氛、茶馆、温室、歌剧沙龙等内容与预约体验使用。",
  "color": {
    "light": {
      "bg": "#f5f0e6",
      "bg-subtle": "#ede6d6",
      "bg-elevated": "#fffdf6",
      "bg-sunken": "#e5dcc8",
      "fg": "#2a2820",
      "fg-muted": "#514c3e",
      "fg-subtle": "#756e5b",
      "fg-on-accent": "#f5f0e6",
      "border": "#ddd3bd",
      "border-strong": "#3e3a2c",
      "primary": "#3e6b5e",
      "primary-hover": "#345a4f",
      "primary-active": "#284740",
      "primary-fg": "#f5f0e6",
      "accent": "#7d6212",
      "accent-fg": "#f5f0e6",
      "success": "#3e7a4e",
      "success-bg": "#e6f1e6",
      "success-fg": "#0e3a22",
      "warning": "#8a6d18",
      "warning-bg": "#f5ecce",
      "warning-fg": "#42330a",
      "danger": "#a8423a",
      "danger-bg": "#f6e2df",
      "danger-fg": "#561712",
      "info": "#3a6478",
      "info-bg": "#e2edf2",
      "info-fg": "#16323e",
      "focus": "#3e6b5e"
    },
    "dark": {
      "bg": "#181c18",
      "bg-subtle": "#1f241f",
      "bg-elevated": "#252b25",
      "bg-sunken": "#11140f",
      "fg": "#ece4d2",
      "fg-muted": "#aaa48f",
      "fg-subtle": "#7e7866",
      "fg-on-accent": "#11140f",
      "border": "#353c33",
      "border-strong": "#b89a4a",
      "primary": "#6fae90",
      "primary-hover": "#82bda0",
      "primary-active": "#5e9a7e",
      "primary-fg": "#11140f",
      "accent": "#cba24e",
      "accent-fg": "#1a1408",
      "success": "#6fbf86",
      "success-bg": "#0e2a1a",
      "success-fg": "#cdeed7",
      "warning": "#cba24e",
      "warning-bg": "#241c08",
      "warning-fg": "#f6e6be",
      "danger": "#e08078",
      "danger-bg": "#2a100e",
      "danger-fg": "#f8d6d2",
      "info": "#6fa6bd",
      "info-bg": "#0e2530",
      "info-fg": "#cfe7f2",
      "focus": "#6fae90"
    }
  },
  "radius": {
    "sm": "4px",
    "md": "10px",
    "lg": "18px",
    "full": "9999px"
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "32px",
    "8": "40px",
    "9": "48px",
    "10": "64px",
    "11": "80px",
    "12": "96px"
  },
  "font": {
    "serif": "\"Noto Serif\", Georgia, \"Songti SC\", serif",
    "sans": "\"Inter\", -apple-system, \"PingFang SC\", sans-serif",
    "mono": "\"JetBrains Mono\", monospace"
  },
  "text": {
    "xs": "13px",
    "sm": "14px",
    "base": "17px",
    "md": "19px",
    "lg": "22px",
    "xl": "28px",
    "2xl": "38px",
    "3xl": "52px"
  },
  "leading": {
    "tight": "1.25",
    "normal": "1.55",
    "relaxed": "1.85"
  },
  "weight": {
    "normal": "400",
    "medium": "500",
    "bold": "600"
  },
  "tracking": {
    "tight": "-0.015em",
    "normal": "0"
  },
  "shadow": {
    "light": {
      "sm": "0 1px 2px rgba(42,40,32,.06)",
      "md": "0 8px 22px -12px rgba(42,40,32,.2)",
      "lg": "0 16px 40px -16px rgba(42,40,32,.24)"
    },
    "dark": {
      "sm": "0 1px 2px rgba(0,0,0,.5)",
      "md": "0 8px 22px -12px rgba(0,0,0,.6)",
      "lg": "0 16px 40px -16px rgba(0,0,0,.7)"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.22,.61,.36,1)",
    "dur-fast": "160ms",
    "dur-base": "240ms",
    "dur-slow": "300ms"
  },
  "reading": {
    "container-max": "680px",
    "note": "编辑容器 max-width 约 40rem/680px；大标题用 Noto Serif 与 generous spacing；正文走 Inter / PingFang SC、大行高。装饰只用于拱形框、分隔线与角花，不侵入正文可读区。"
  }
}
