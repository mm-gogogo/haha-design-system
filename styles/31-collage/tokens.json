  "font": {
    "sans": "\"Quicksand\",\"Inter\",-apple-system,\"PingFang SC\",sans-serif",
    "serif": "\"Noto Serif\",Georgia,serif",
    "mono": "\"JetBrains Mono\",monospace"
  },
  "text": {
    "xs": "12px",
