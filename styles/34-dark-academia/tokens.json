{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "dark-academia",
  "description": "Dark Academia · 暗黑学院风。Aged manuscript paper, oxblood, bottle green, candlelit brass, serif-forward reading, footnotes, marginalia, wax seals, ribbon bookmarks, and ex-libris catalogue cards.",
  "color": {
    "light": {
      "bg": "#ece3d0",
      "bg-subtle": "#e2d6bd",
      "bg-elevated": "#f6efdd",
      "bg-sunken": "#d6c8a8",
      "fg": "#2a2018",
      "fg-muted": "#5a4a38",
      "fg-subtle": "#776550",
      "fg-on-accent": "#f6efdd",
      "border": "#cdbd9c",
      "border-strong": "#2a2018",
      "brass": "#9a7b2e",
      "primary": "#7c2b22",
      "primary-hover": "#6a241c",
      "primary-active": "#561a14",
      "primary-fg": "#f6efdd",
      "accent": "#2f4a32",
      "accent-fg": "#f6efdd",
      "success": "#3a6b2e",
      "success-bg": "#e6efe0",
      "success-fg": "#173310",
      "warning": "#9a6a14",
      "warning-bg": "#f4e8cf",
      "warning-fg": "#43300a",
      "danger": "#7c2b22",
      "danger-bg": "#f3e0db",
      "danger-fg": "#4a130d",
      "info": "#2f4a52",
      "info-bg": "#e0eaec",
      "info-fg": "#0e2429",
      "focus": "#7c2b22"
    },
    "dark": {
      "bg": "#16110c",
      "bg-subtle": "#1d1610",
      "bg-elevated": "#231b13",
      "bg-sunken": "#0e0a06",
      "fg": "#ece0c8",
      "fg-muted": "#b09a78",
      "fg-subtle": "#847058",
      "fg-on-accent": "#f6efdd",
      "border": "#38291c",
      "border-strong": "#c9a86a",
      "brass": "#c9a86a",
      "primary": "#b8463a",
      "primary-hover": "#c8564a",
      "primary-active": "#a83c30",
      "primary-fg": "#f6efdd",
      "accent": "#8fb07a",
      "accent-fg": "#0e1a08",
      "success": "#6fbf6f",
      "success-bg": "#102a10",
      "success-fg": "#cdeec0",
      "warning": "#d8b25a",
      "warning-bg": "#241a06",
      "warning-fg": "#f6e6be",
      "danger": "#d8584a",
      "danger-bg": "#2a0e0a",
      "danger-fg": "#f8d6cf",
      "info": "#5fa0a8",
      "info-bg": "#08222a",
      "info-fg": "#d6eef2",
      "focus": "#b8463a"
    }
  },
  "radius": {
    "sm": "3px",
    "md": "6px",
    "lg": "10px",
    "full": "9999px"
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "32px",
    "8": "40px",
    "9": "48px",
    "10": "64px",
    "11": "80px",
    "12": "96px"
  },
  "font": {
    "serif": "\"Noto Serif\", Georgia, serif",
    "sans": "\"Inter\", -apple-system, \"PingFang SC\", sans-serif",
    "mono": "\"JetBrains Mono\", monospace"
  },
  "text": {
    "xs": "13px",
    "sm": "14px",
    "base": "17px",
    "md": "19px",
    "lg": "22px",
    "xl": "28px",
    "2xl": "38px",
    "3xl": "52px"
  },
  "leading": {
    "tight": "1.25",
    "normal": "1.55",
    "relaxed": "1.85"
  },
  "weight": {
    "normal": "400",
    "medium": "500",
    "bold": "600"
  },
  "tracking": {
    "tight": "-0.015em",
    "normal": "0"
  },
  "shadow": {
    "light": {
      "sm": "0 1px 2px rgba(42,32,24,.14)",
      "md": "0 5px 16px -6px rgba(42,32,24,.24)",
      "lg": "0 16px 36px -12px rgba(42,32,24,.32)"
    },
    "dark": {
      "sm": "0 1px 2px rgba(0,0,0,.5)",
      "md": "0 5px 16px -6px rgba(0,0,0,.6)",
      "lg": "0 16px 36px -12px rgba(0,0,0,.72)"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.22,.61,.36,1)",
    "dur-fast": "160ms",
    "dur-base": "240ms",
    "dur-slow": "300ms"
  },
  "reading": {
    "container-max": "680px",
    "note": "Reading column maxes at 680px; marginalia sits beside the column on desktop and collapses below text on narrow screens."
  }
}
