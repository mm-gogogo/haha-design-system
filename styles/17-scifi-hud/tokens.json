{
  "$meta": {
    "name": "Orbit HUD / 航天终端 · 科幻 HUD",
    "description": "暗色优先的航天/轨道控制台风。深蓝黑海军底 + 一束克制的离子蓝辉光 + 玻璃面板 + 等宽坐标/状态标注。精密昂贵，区别于繁忙霓虹赛博。注意 :root=暗色，[data-theme=\"light\"]/.light 为亮色覆盖（与多数风格相反）。",
    "version": "1.0.0",
    "contract": "ds-token-contract@1",
    "themeStrategy": "dark-first",
    "base": "dark",
    "override": "light"
  },
  "color": {
    "dark": {
      "bg": "#060810",
      "bg-subtle": "#0b0f1c",
      "bg-elevated": "#101626",
      "bg-sunken": "#04060c",
      "fg": "#e8eefc",
      "fg-muted": "#8a99bd",
      "fg-subtle": "#5a6788",
      "fg-on-accent": "#04101f",
      "border": "#1b2740",
      "border-strong": "#2c3c5e",
      "primary": "#4d8dff",
      "primary-hover": "#6ba2ff",
      "primary-active": "#2f74ef",
      "primary-fg": "#04101f",
      "accent": "#56c8ff",
      "accent-fg": "#021018",
      "success": "#3ee08f", "success-bg": "#06231a", "success-fg": "#b6ffd9",
      "warning": "#ffb53d", "warning-bg": "#271a04", "warning-fg": "#ffe6b8",
      "danger": "#ff5c72", "danger-bg": "#2a0b12", "danger-fg": "#ffccd4",
      "info": "#4d8dff", "info-bg": "#08172e", "info-fg": "#cfe0ff",
      "focus": "#4d8dff"
    },
    "light": {
      "bg": "#f7f9fe",
      "bg-subtle": "#eef2fb",
      "bg-elevated": "#ffffff",
      "bg-sunken": "#e7edf8",
      "fg": "#0a1222",
      "fg-muted": "#46546f",
      "fg-subtle": "#687792",
      "fg-on-accent": "#ffffff",
      "border": "#dde4f0",
      "border-strong": "#c2cde0",
      "primary": "#1f5fe0",
      "primary-hover": "#1a54c8",
      "primary-active": "#1748ab",
      "primary-fg": "#ffffff",
      "accent": "#0f6fd6",
      "accent-fg": "#ffffff",
      "success": "#07823f", "success-bg": "#e6f8ee", "success-fg": "#044523",
      "warning": "#9a6400", "warning-bg": "#fff4e0", "warning-fg": "#4d3200",
      "danger": "#d11a3f", "danger-bg": "#ffe9ee", "danger-fg": "#6b0a20",
      "info": "#0073c4", "info-bg": "#e5f3ff", "info-fg": "#003a66",
      "focus": "#1f5fe0"
    }
  },
  "focusRing": {
    "dark": "0 0 0 2px #060810, 0 0 0 4px #4d8dff, 0 0 16px -2px rgba(77,141,255,.6)",
    "light": "0 0 0 2px #f7f9fe, 0 0 0 4px #1f5fe0, 0 0 12px -3px rgba(31,95,224,.4)"
  },
  "radius": {
    "sm": "4px",
    "md": "8px",
    "lg": "12px",
    "full": "9999px"
  },
  "space": {
    "1": "4px", "2": "8px", "3": "12px", "4": "16px",
    "5": "20px", "6": "24px", "7": "32px", "8": "40px",
    "9": "48px", "10": "64px", "11": "80px", "12": "96px"
  },
  "font": {
    "sans": "\"Inter\", -apple-system, \"Segoe UI\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
    "serif": "\"Noto Serif\", Georgia, \"Songti SC\", serif",
    "mono": "\"JetBrains Mono\", ui-monospace, \"SF Mono\", Menlo, Consolas, monospace"
  },
  "fontSize": {
    "xs": "12px", "sm": "13px", "base": "14px", "md": "16px",
    "lg": "20px", "xl": "24px", "2xl": "32px", "3xl": "48px"
  },
  "leading": {
    "tight": "1.2",
    "normal": "1.5",
    "relaxed": "1.7"
  },
  "weight": {
    "normal": "400",
    "medium": "500",
    "bold": "600"
  },
  "tracking": {
    "tight": "-0.02em",
    "normal": "0"
  },
  "shadow": {
    "dark": {
      "sm": "0 0 0 1px #1b2740, 0 2px 8px -2px rgba(0,0,0,.7)",
      "md": "0 0 0 1px #1b2740, 0 12px 32px -10px rgba(0,0,0,.8), 0 0 28px -12px rgba(77,141,255,.25)",
