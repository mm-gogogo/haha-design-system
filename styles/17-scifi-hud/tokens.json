    },
    "light": {
      "sm": "0 0 0 1px #dde4f0, 0 2px 6px -2px rgba(10,18,34,.08)",
      "md": "0 0 0 1px #dde4f0, 0 10px 28px -10px rgba(10,18,34,.14), 0 0 22px -12px rgba(31,95,224,.16)",
      "lg": "0 0 0 1px #dde4f0, 0 20px 56px -14px rgba(10,18,34,.18), 0 0 30px -14px rgba(31,95,224,.2)"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.2,.8,.2,1)",
    "dur-fast": "150ms",
    "dur-base": "200ms",
    "dur-slow": "250ms"
  }
}
